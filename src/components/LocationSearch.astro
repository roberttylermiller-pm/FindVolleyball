<form class="location-search">
  <input type="text" name="location" placeholder="Search city, state, or zip" />
  <button type="submit">Search</button>
</form>

<style>
  .location-search {
    display: flex;
    /* Shrinkable (not just sized to content) so the form gives up
       width to its sibling Filters toggle (index.astro's
       .map-controls-row) on a narrow phone rather than the two of them
       fighting over a fixed pixel budget computed against a guessed
       viewport width — ROB-120 follow-up. min-width: 0 overrides
       flexbox's default of never shrinking below content size. */
    flex: 1 1 auto;
    min-width: 0;
    gap: 0.5rem;
    /* No background/padding/shadow of its own (ROB-158) — this now sits
       inside index.astro's .map-controls-row, which is the single
       unified bar (search + Filters + List) matching the volleymap
       reference Robert liked. */

    input {
      /* The actual flexible element — shrinks to whatever's left over
         after the Search button and Filters toggle take what they
         need, down to a small floor that's still typeable rather than
         a sliver. */
      flex: 1 1 auto;
      min-width: 3rem;
      padding: 0.4rem 0.6rem;
      font-size: 0.875rem;
      border: 1px solid #ccc;
      border-radius: 0.25rem;
    }

    button {
      flex-shrink: 0;
      padding: 0.4rem 0.75rem;
      font-size: 0.875rem;
      color: white;
      background: var(--color-accent);
      border: none;
      border-radius: 0.25rem;
      cursor: pointer;
    }
  }
</style>

<script>
  import { geocodeLocation } from '../lib/geocode';
  import { MAP_PAN_TO_EVENT } from '../lib/map/events';

  const form = document.querySelector<HTMLFormElement>('.location-search');

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();

    const input = form.querySelector<HTMLInputElement>('input[name="location"]');
    const query = input?.value.trim();
    if (!query) return;

    try {
      const result = await geocodeLocation(query);
      if (!result) {
        alert(`Couldn't find "${query}". Try a different city, state, or zip.`);
        return;
      }
      window.dispatchEvent(new CustomEvent(MAP_PAN_TO_EVENT, { detail: result }));
    } catch (err) {
      console.error(err);
      alert('Location search failed. Please try again.');
    }
  });
</script>
