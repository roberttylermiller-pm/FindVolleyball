<div id="welcome-modal" class="welcome-modal" hidden>
  <div class="welcome-card">
    <h2>Welcome to Find Volleyball!</h2>
    <p>
      This is a community powered map designed to help you find places to play Volleyball of all kinds. We're in
      the early stages so it's currently focused on the Greater Los Angeles region but please add any listings you
      know of.
    </p>
    <button type="button" id="welcome-dismiss">Explore the map</button>
  </div>
</div>

<style>
  .welcome-modal:not([hidden]) {
    position: fixed;
    inset: 0;
    z-index: 2000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    background: rgb(0 0 0 / 45%);
  }

  .welcome-card {
    max-width: 24rem;
    padding: 1.5rem;
    background: white;
    border-radius: 0.75rem;
    box-shadow: 0 4px 20px rgb(0 0 0 / 25%);

    h2 {
      margin: 0 0 0.5rem;
      font-size: 1.15rem;
    }

    p {
      margin: 0 0 1.25rem;
      font-size: 0.9rem;
      line-height: 1.5;
      color: #444;
    }

    button {
      width: 100%;
      padding: 0.6rem;
      font-size: 0.95rem;
      font-weight: 600;
      color: white;
      background: var(--color-accent);
      border: none;
      border-radius: 0.4rem;
      cursor: pointer;
    }
  }
</style>

<script>
  const STORAGE_KEY = 'fv-welcome-seen';

  const modal = document.querySelector<HTMLDivElement>('#welcome-modal');
  const dismissBtn = document.querySelector<HTMLButtonElement>('#welcome-dismiss');

  if (modal && !localStorage.getItem(STORAGE_KEY)) {
    modal.hidden = false;
  }

  dismissBtn?.addEventListener('click', () => {
    if (modal) modal.hidden = true;
    localStorage.setItem(STORAGE_KEY, 'true');
  });
</script>
