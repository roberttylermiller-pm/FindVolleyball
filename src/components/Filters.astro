<div class="filters">
  <fieldset>
    <legend>Type</legend>
    <label class="chip"><input type="checkbox" name="type" value="indoor" checked /><span>Indoor</span></label>
    <label class="chip"><input type="checkbox" name="type" value="grass" checked /><span>Grass</span></label>
    <label class="chip"><input type="checkbox" name="type" value="beach" checked /><span>Sand</span></label>
  </fieldset>
  <div class="filters-divider"></div>
  <fieldset>
    <legend>Cost</legend>
    <label class="chip"><input type="checkbox" name="cost" value="free" checked /><span>Free</span></label>
    <label class="chip"><input type="checkbox" name="cost" value="paid" checked /><span>Paid</span></label>
  </fieldset>
  <div class="filters-divider"></div>
  <fieldset>
    <legend>Kind</legend>
    <label class="chip"><input type="checkbox" name="kind" value="recurring" checked /><span>Meetup</span></label>
    <label class="chip"><input type="checkbox" name="kind" value="tournament" checked /><span>Tournament</span></label>
    <label class="chip"><input type="checkbox" name="kind" value="league" checked /><span>League</span></label>
  </fieldset>
  <div class="filters-divider"></div>
  <fieldset>
    <legend>Day</legend>
    <label class="chip"><input type="checkbox" name="day" value="sun" checked /><span>Sun</span></label>
    <label class="chip"><input type="checkbox" name="day" value="mon" checked /><span>Mon</span></label>
    <label class="chip"><input type="checkbox" name="day" value="tue" checked /><span>Tue</span></label>
    <label class="chip"><input type="checkbox" name="day" value="wed" checked /><span>Wed</span></label>
    <label class="chip"><input type="checkbox" name="day" value="thu" checked /><span>Thu</span></label>
    <label class="chip"><input type="checkbox" name="day" value="fri" checked /><span>Fri</span></label>
    <label class="chip"><input type="checkbox" name="day" value="sat" checked /><span>Sat</span></label>
  </fieldset>
  <div class="filters-divider"></div>
  <button type="button" id="filters-clear-all" class="clear-all">Clear all</button>
</div>

<style>
  .filters {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 0.6rem;
    max-width: 22rem;
    padding: 0.5rem 0.65rem;
    background: #1a1a1a;
    border-radius: 0.5rem;
    box-shadow: 0 1px 4px rgb(0 0 0 / 20%);

    fieldset {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.35rem;
      margin: 0;
      padding: 0;
      border: none;

      legend {
        /* Visually hidden but still announced by screen readers — the
           chip labels (Indoor/Grass/Sand) are self-explanatory without
           a "Type:" prefix, and dropping it keeps the panel compact. */
        position: absolute;
        width: 1px;
        height: 1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
      }
    }

    .filters-divider {
      width: 1px;
      height: 1.1rem;
      background: rgb(255 255 255 / 15%);
    }

    .chip {
      position: relative;
      display: inline-flex;
      align-items: center;
      padding: 0.3rem 0.65rem;
      font-size: 0.75rem;
      color: #ccc;
      background: rgb(255 255 255 / 8%);
      border-radius: 999px;
      cursor: pointer;
      user-select: none;
      transition: background 0.15s, color 0.15s;

      input {
        position: absolute;
        width: 0;
        height: 0;
        opacity: 0;
      }

      &:has(input:checked) {
        color: white;
        background: var(--color-accent);
      }
    }

    .clear-all {
      padding: 0.3rem 0.5rem;
      font-size: 0.75rem;
      color: #999;
      background: none;
      border: none;
      cursor: pointer;
      white-space: nowrap;
      transition: color 0.15s;
    }

    .clear-all:hover {
      color: white;
    }
  }
</style>

<script>
  import { LISTING_FILTERS_EVENT } from '../lib/listings/filters';
  import type { ListingFilters } from '../lib/listings/filters';

  const container = document.querySelector<HTMLDivElement>('.filters');

  function readFilters(scope: HTMLDivElement): ListingFilters {
    const types = Array.from(scope.querySelectorAll<HTMLInputElement>('input[name="type"]:checked')).map(
      (el) => el.value,
    );
    const costs = Array.from(scope.querySelectorAll<HTMLInputElement>('input[name="cost"]:checked')).map(
      (el) => el.value,
    );
    const days = Array.from(scope.querySelectorAll<HTMLInputElement>('input[name="day"]:checked')).map(
      (el) => el.value,
    );
    const kinds = Array.from(scope.querySelectorAll<HTMLInputElement>('input[name="kind"]:checked')).map(
      (el) => el.value,
    );
    return {
      types: new Set(types) as ListingFilters['types'],
      costs: new Set(costs) as ListingFilters['costs'],
      days: new Set(days) as ListingFilters['days'],
      kinds: new Set(kinds) as ListingFilters['kinds'],
    };
  }

  container?.addEventListener('change', () => {
    window.dispatchEvent(new CustomEvent<ListingFilters>(LISTING_FILTERS_EVENT, { detail: readFilters(container) }));
  });

  const clearAllButton = document.querySelector<HTMLButtonElement>('#filters-clear-all');
  clearAllButton?.addEventListener('click', () => {
    if (!container) return;
    container.querySelectorAll<HTMLInputElement>('input[type="checkbox"]').forEach((input) => {
      input.checked = false;
    });
    window.dispatchEvent(new CustomEvent<ListingFilters>(LISTING_FILTERS_EVENT, { detail: readFilters(container) }));
  });
</script>
