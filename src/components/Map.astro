---
import 'leaflet/dist/leaflet.css';
import 'leaflet.markercluster/dist/MarkerCluster.css';
import 'leaflet.markercluster/dist/MarkerCluster.Default.css';
---

<div id="map"></div>

<style>
  #map {
    width: 100%;
    height: 100%;
  }
</style>

<style is:global>
  /* Marker badge — emoji + dark circle, not an image asset (no broken-
     icon risk under a bundler), matches the dark/high-tech direction. */
  .volleyball-marker-badge {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    font-size: 21px;
    background: #1a1a1a;
    border: 2px solid white;
    border-radius: 50%;
    box-shadow: 0 2px 6px rgb(0 0 0 / 35%);
  }

  /* Surface badge (ROB-67) — small emoji pinned to the corner so the
     marker reads as "volleyball, and here's the surface" at a glance. */
  .volleyball-marker-type {
    position: absolute;
    right: -5px;
    bottom: -5px;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    font-size: 13px;
    line-height: 1;
    background: white;
    border-radius: 50%;
    box-shadow: 0 1px 2px rgb(0 0 0 / 40%);
  }

  /* Restyle marker clusters to match (default plugin styling is green/
     yellow/orange circles, which clashed with the dark marker badges). */
  .marker-cluster-small,
  .marker-cluster-medium,
  .marker-cluster-large {
    background-color: rgb(26 26 26 / 60%);
  }

  .marker-cluster-small div,
  .marker-cluster-medium div,
  .marker-cluster-large div {
    background-color: #1a1a1a;
    color: white;
  }

  /* Dark popup theme. Leaflet appends popup DOM outside any Astro
     component's scoped tree, so this has to be global. */
  .volleyball-popup .leaflet-popup-content-wrapper {
    background: #1a1a1a;
    color: #e5e5e5;
    border-radius: 0.5rem;
  }

  .volleyball-popup .leaflet-popup-tip {
    background: #1a1a1a;
  }

  .volleyball-popup .leaflet-popup-close-button {
    color: #999;
  }

  .listing-popup {
    font-size: 0.85rem;
    line-height: 1.5;
    min-width: 14rem;
  }

  .listing-popup .popup-photo {
    width: 100%;
    height: 8rem;
    object-fit: cover;
    border-radius: 0.4rem;
    margin-bottom: 0.5rem;
  }

  .listing-popup .popup-title-row {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 0.25rem;
  }

  .listing-popup .popup-title {
    font-size: 0.95rem;
    color: white;
  }

  .listing-popup .popup-decayed {
    padding: 0.1rem 0.4rem;
    font-size: 0.65rem;
    font-weight: 600;
    color: #856404;
    background: #fff3cd;
    border-radius: 0.25rem;
  }

  .listing-popup .popup-decayed-notice {
    margin-bottom: 0.4rem;
    padding: 0.35rem 0.5rem;
    color: #ffe9b3;
    font-size: 0.75rem;
    background: rgb(255 193 7 / 12%);
    border-left: 2px solid #ffc107;
    border-radius: 0.2rem;
  }

  .listing-popup .popup-address {
    display: block;
    margin: 0 -0.2rem 0.35rem;
    padding: 0.3rem 0.2rem;
    color: #ccc;
    font-size: 0.8rem;
    text-decoration: underline;
    border-radius: 0.25rem;
  }

  .listing-popup .popup-address:hover {
    color: #fff;
    background: rgb(255 255 255 / 8%);
  }

  .listing-popup .popup-meta {
    margin-bottom: 0.35rem;
    color: #aaa;
  }

  .listing-popup .popup-row {
    color: #ccc;
  }

  .listing-popup .popup-notes {
    margin-top: 0.35rem;
    color: #ccc;
    font-style: italic;
  }

  .listing-popup .popup-link {
    display: inline-block;
    margin-top: 0.5rem;
    color: var(--color-accent);
    font-weight: 600;
    text-decoration: none;
  }

  .listing-popup .popup-votes {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 0.6rem;
    padding-top: 0.5rem;
    border-top: 1px solid #333;
  }

  .listing-popup .popup-votes button {
    padding: 0.15rem 0.45rem;
    font-size: 0.95rem;
    background: rgb(255 255 255 / 8%);
    border: none;
    border-radius: 0.3rem;
    cursor: pointer;
  }

  .listing-popup .popup-votes button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .listing-popup .popup-vote-message {
    color: #ccc;
    font-size: 0.75rem;
  }

  .listing-popup .popup-report-toggle {
    display: block;
    margin-top: 0.5rem;
    padding: 0;
    color: #999;
    font-size: 0.75rem;
    background: none;
    border: none;
    text-decoration: underline;
    cursor: pointer;
  }

  .listing-popup .popup-report-form:not([hidden]) {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-top: 0.4rem;
  }

  /* Honeypot — present in the DOM but invisible/unreachable for a real
     user. Doesn't use [hidden] since some bots specifically skip
     hidden-attribute fields; off-screen positioning catches those too. */
  .listing-popup .popup-honeypot {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    left: -9999px;
  }

  .listing-popup .popup-report-form textarea {
    padding: 0.4rem;
    font-family: inherit;
    font-size: 0.8rem;
    color: #e5e5e5;
    background: rgb(255 255 255 / 8%);
    border: 1px solid #444;
    border-radius: 0.25rem;
  }

  .listing-popup .popup-report-form button[type="submit"] {
    align-self: flex-start;
    padding: 0.3rem 0.75rem;
    font-size: 0.75rem;
    color: white;
    background: var(--color-accent);
    border: none;
    border-radius: 0.25rem;
    cursor: pointer;
  }

  .listing-popup .popup-report-message {
    margin: 0.3rem 0 0;
    color: #ccc;
    font-size: 0.75rem;
  }

  .listing-popup .popup-permalink {
    display: inline-block;
    margin-top: 0.5rem;
    color: #777;
    font-size: 0.7rem;
  }
</style>

<script>
  import L from 'leaflet';
  import 'leaflet.markercluster';
  import { DEFAULT_MAP_CENTER, DEFAULT_MAP_ZOOM, USER_LOCATION_ZOOM, TILE_LAYER_URL, TILE_LAYER_ATTRIBUTION } from '../lib/map/constants';
  import { createVolleyballIcon } from '../lib/map/volleyballIcon';
  import { fetchApprovedListings } from '../lib/listings/fetchApproved';
  import { LISTING_FILTERS_EVENT, defaultListingFilters, listingMatchesFilters } from '../lib/listings/filters';
  import type { ListingFilters } from '../lib/listings/filters';
  import { MAP_PAN_TO_EVENT } from '../lib/map/events';
  import type { MapPanToDetail } from '../lib/map/events';
  import { buildListingPopupContent } from '../lib/listings/popup';
  import type { Listing } from '../types/listing';

  // Default zoom control sits top-left, the same corner as the search/
  // filter overlay — moved to bottom-right so they can never collide
  // regardless of viewport width.
  const map = L.map('map', { zoomControl: false }).setView(DEFAULT_MAP_CENTER, DEFAULT_MAP_ZOOM);
  L.control.zoom({ position: 'bottomright' }).addTo(map);

  // Re-centers on the visitor's own location once geolocation resolves
  // — listings now span more than the original seed region, so the
  // fixed regional default is a worse first view than it used to be
  // for someone outside it. Silently keeps today's default view if
  // permission is denied/unavailable/slow — no fallback UI needed
  // since the map is already usable at that default the instant it
  // loads, geolocation only ever improves on it from there.
  if ('geolocation' in navigator) {
    navigator.geolocation.getCurrentPosition(
      (position) => {
        map.setView([position.coords.latitude, position.coords.longitude], USER_LOCATION_ZOOM);
      },
      () => {
        // Permission denied, unavailable, or timed out — no-op.
      },
      { timeout: 8000, maximumAge: 5 * 60 * 1000 },
    );
  }

  L.tileLayer(TILE_LAYER_URL, {
    attribution: TILE_LAYER_ATTRIBUTION,
    maxZoom: 19,
  }).addTo(map);

  // Different orgs sometimes list meetups at the exact same gym/lat-lng.
  // spiderfyOnMaxZoom (on by default, set explicitly here for clarity)
  // is what makes that graceful: clicking a cluster whose members can't
  // be separated by zooming any further fans them out into a small ring
  // instead of just picking one to show, so every listing stays reachable
  // — no de-dup or coordinate-nudging needed on our end.
  const clusterGroup = L.markerClusterGroup({ spiderfyOnMaxZoom: true, zoomToBoundsOnClick: true });
  map.addLayer(clusterGroup);

  let allListings: Listing[] = [];

  function renderMarkers(filters: ListingFilters) {
    clusterGroup.clearLayers();
    for (const listing of allListings) {
      if (!listingMatchesFilters(listing, filters)) continue;
      const marker = L.marker([listing.lat, listing.lng], {
        icon: createVolleyballIcon(listing.type, listing.listing_kind),
        opacity: listing.decayed ? 0.5 : 1,
      });
      // autoPan: false — see the popupopen handler below for why
      // Leaflet's own version of this can't be left enabled (ROB-119).
      marker.bindPopup(buildListingPopupContent(listing), { className: 'volleyball-popup', maxWidth: 260, autoPan: false });
      clusterGroup.addLayer(marker);
    }
  }

  // Leaflet's built-in popup autoPan (disabled above, see bindPopup)
  // re-runs on every subsequent map move while a popup is open, not
  // just once at open time — so any manual map.panBy() call made while
  // a popup is showing gets partially fought/undone by Leaflet's own
  // autoPan reacting to that same move (confirmed directly: a manual
  // panBy([0,-220]) only netted +120px of actual on-screen movement
  // with autoPan left on). On iOS this combination of two competing
  // pan systems reliably left the popup positioned off-screen once both
  // settled, reading as the popup just vanishing once the screen
  // stopped moving (ROB-119). Disabling Leaflet's version and doing all
  // of this ourselves — both the map's own edges (its job before) and
  // the .map-controls overlay it doesn't know about (ROB-117) — avoids
  // the conflict entirely instead of trying to out-time it.
  const POPUP_PADDING = 12;

  // Clicking a marker that's part of a cluster (zoomToBoundsOnClick) or
  // a tight group that needs to spiderfy zooms/spreads the map BEFORE
  // the popup opens — and that animation can still be running when
  // 'popupopen' fires. Tracking movestart/zoomstart..moveend/zoomend
  // lets the correction wait that out too, not just a fixed guess at
  // how long any one animation takes.
  let mapIsBusy = false;
  map.on('movestart zoomstart', () => {
    mapIsBusy = true;
  });
  map.on('moveend zoomend', () => {
    mapIsBusy = false;
  });

  map.on('popupopen', (event) => {
    function applyCorrection() {
      const popupEl = event.popup.getElement();
      const controls = document.querySelector('.map-controls');
      if (!popupEl) return;

      const popupRect = popupEl.getBoundingClientRect();
      const mapRect = map.getContainer().getBoundingClientRect();
      const topBound = controls ? Math.max(mapRect.top, controls.getBoundingClientRect().bottom) : mapRect.top;

      // panBy's sign convention, confirmed empirically: a negative
      // component moves page content down/right; positive moves it
      // up/left.
      let dy = 0;
      if (popupRect.top < topBound) {
        dy = -(topBound - popupRect.top + POPUP_PADDING);
      } else if (popupRect.bottom > mapRect.bottom) {
        dy = popupRect.bottom - mapRect.bottom + POPUP_PADDING;
      }

      let dx = 0;
      if (popupRect.left < mapRect.left) {
        dx = -(mapRect.left - popupRect.left + POPUP_PADDING);
      } else if (popupRect.right > mapRect.right) {
        dx = popupRect.right - mapRect.right + POPUP_PADDING;
      }

      if (dx !== 0 || dy !== 0) {
        // animate: false — an animated pan here turned out to depend
        // on requestAnimationFrame to actually progress, and there are
        // real conditions (reduced-motion settings, throttled
        // background tabs, certain mobile browser states) where rAF
        // doesn't reliably drive a transition forward. Since this
        // correction only fires when the popup would otherwise be
        // genuinely unreadable, landing it in the right place
        // instantly and deterministically matters more than animating
        // the hop smoothly.
        map.panBy([dx, dy], { animate: false });
      }
    }

    // A cluster-triggered zoom/spiderfy started before this popup even
    // opened — wait for it to actually finish before measuring, rather
    // than guessing a fixed delay that a slower device or a chained
    // zoom-then-spiderfy could still outlast.
    if (mapIsBusy) {
      map.once('moveend zoomend', () => setTimeout(applyCorrection, 50));
    } else {
      setTimeout(applyCorrection, 50);
    }
  });

  window.addEventListener(LISTING_FILTERS_EVENT, (event) => {
    renderMarkers((event as CustomEvent<ListingFilters>).detail);
  });

  window.addEventListener(MAP_PAN_TO_EVENT, (event) => {
    const { boundingBox } = (event as CustomEvent<MapPanToDetail>).detail;
    const [south, north, west, east] = boundingBox;
    map.fitBounds([
      [south, west],
      [north, east],
    ]);
  });

  try {
    allListings = await fetchApprovedListings();
    renderMarkers(defaultListingFilters());
  } catch (err) {
    console.error(err);
  }
</script>
