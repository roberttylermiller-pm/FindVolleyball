---
import 'leaflet/dist/leaflet.css';
import 'leaflet.markercluster/dist/MarkerCluster.css';
import 'leaflet.markercluster/dist/MarkerCluster.Default.css';
---

<div id="map"></div>

<style>
  #map {
    width: 100%;
    height: 100vh;
  }
</style>

<script>
  import L from 'leaflet';
  import 'leaflet.markercluster';
  import markerIcon from 'leaflet/dist/images/marker-icon.png';
  import markerIcon2x from 'leaflet/dist/images/marker-icon-2x.png';
  import markerShadow from 'leaflet/dist/images/marker-shadow.png';
  import { DEFAULT_MAP_CENTER, DEFAULT_MAP_ZOOM } from '../lib/map/constants';
  import { fetchApprovedListings } from '../lib/listings/fetchApproved';
  import { LISTING_FILTERS_EVENT, defaultListingFilters, listingMatchesFilters } from '../lib/listings/filters';
  import type { ListingFilters } from '../lib/listings/filters';
  import { MAP_PAN_TO_EVENT } from '../lib/map/events';
  import type { MapPanToDetail } from '../lib/map/events';
  import { buildListingPopupHtml } from '../lib/listings/popup';
  import type { Listing } from '../types/listing';

  // Leaflet's default marker icon paths assume a non-bundled asset layout;
  // under Vite they 404 unless re-pointed at the bundled URLs.
  delete (L.Icon.Default.prototype as { _getIconUrl?: unknown })._getIconUrl;
  L.Icon.Default.mergeOptions({
    iconUrl: markerIcon,
    iconRetinaUrl: markerIcon2x,
    shadowUrl: markerShadow,
  });

  const map = L.map('map').setView(DEFAULT_MAP_CENTER, DEFAULT_MAP_ZOOM);

  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
    maxZoom: 19,
  }).addTo(map);

  const clusterGroup = L.markerClusterGroup();
  map.addLayer(clusterGroup);

  let allListings: Listing[] = [];

  function renderMarkers(filters: ListingFilters) {
    clusterGroup.clearLayers();
    for (const listing of allListings) {
      if (!listingMatchesFilters(listing, filters)) continue;
      const marker = L.marker([listing.lat, listing.lng]);
      marker.bindPopup(buildListingPopupHtml(listing));
      clusterGroup.addLayer(marker);
    }
  }

  window.addEventListener(LISTING_FILTERS_EVENT, (event) => {
    renderMarkers((event as CustomEvent<ListingFilters>).detail);
  });

  window.addEventListener(MAP_PAN_TO_EVENT, (event) => {
    const { boundingBox } = (event as CustomEvent<MapPanToDetail>).detail;
    const [south, north, west, east] = boundingBox;
    map.fitBounds([
      [south, west],
      [north, east],
    ]);
  });

  try {
    allListings = await fetchApprovedListings();
    renderMarkers(defaultListingFilters());
  } catch (err) {
    console.error(err);
  }
</script>
