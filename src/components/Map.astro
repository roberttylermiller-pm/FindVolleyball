---
import 'leaflet/dist/leaflet.css';
import 'leaflet.markercluster/dist/MarkerCluster.css';
import 'leaflet.markercluster/dist/MarkerCluster.Default.css';
---

<div id="map"></div>

<style>
  #map {
    width: 100%;
    height: 100%;
  }
</style>

<style is:global>
  /* Marker badge — emoji + dark circle, not an image asset (no broken-
     icon risk under a bundler), matches the dark/high-tech direction. */
  .volleyball-marker-badge {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    font-size: 21px;
    background: #1a1a1a;
    border: 2px solid white;
    border-radius: 50%;
    box-shadow: 0 2px 6px rgb(0 0 0 / 35%);
  }

  /* Surface badge (ROB-67) — small emoji pinned to the corner so the
     marker reads as "volleyball, and here's the surface" at a glance. */
  .volleyball-marker-type {
    position: absolute;
    right: -5px;
    bottom: -5px;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    font-size: 13px;
    line-height: 1;
    background: white;
    border-radius: 50%;
    box-shadow: 0 1px 2px rgb(0 0 0 / 40%);
  }

  /* Restyle marker clusters to match (default plugin styling is green/
     yellow/orange circles, which clashed with the dark marker badges). */
  .marker-cluster-small,
  .marker-cluster-medium,
  .marker-cluster-large {
    background-color: rgb(26 26 26 / 60%);
  }

  .marker-cluster-small div,
  .marker-cluster-medium div,
  .marker-cluster-large div {
    background-color: #1a1a1a;
    color: white;
  }

  /* Dark popup theme. Leaflet appends popup DOM outside any Astro
     component's scoped tree, so this has to be global. */
  .volleyball-popup .leaflet-popup-content-wrapper {
    background: #1a1a1a;
    color: #e5e5e5;
    border-radius: var(--radius-sharp);
  }

  .volleyball-popup .leaflet-popup-tip {
    background: #1a1a1a;
  }

  .volleyball-popup .leaflet-popup-close-button {
    color: #999;
  }

  .listing-popup {
    font-size: 0.85rem;
    line-height: 1.5;
    min-width: 14rem;
  }

  .listing-popup .popup-photo {
    width: 100%;
    height: 8rem;
    object-fit: cover;
    border-radius: var(--radius-sharp);
    margin-bottom: 0.5rem;
  }

  .listing-popup .popup-title-row {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 0.25rem;
  }

  .listing-popup .popup-title {
    font-size: 0.95rem;
    color: white;
    font-family: var(--font-display);
    font-weight: 700;
  }

  .listing-popup .popup-decayed {
    padding: 0.1rem 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #856404;
    background: #fff3cd;
    border-radius: var(--radius-tag);
  }

  /* Icon-only kind differences on the map markers (🏐/🏆/🏟️) aren't
     obvious to everyone, so the popup spells it out in words too. */
  .listing-popup .popup-kind-badge {
    padding: 0.1rem 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #1c1c1e;
    background: #8ab4f8;
    border-radius: var(--radius-tag);
  }

  .listing-popup .popup-kind-tournament {
    background: #ffd166;
  }

  .listing-popup .popup-kind-league {
    background: #8bd3a0;
  }

  .listing-popup .popup-decayed-notice {
    margin-bottom: 0.4rem;
    padding: 0.35rem 0.5rem;
    color: #ffe9b3;
    font-size: 0.75rem;
    background: rgb(255 193 7 / 12%);
    border-left: 2px solid #ffc107;
    border-radius: var(--radius-sharp);
  }

  .listing-popup .popup-address {
    display: block;
    margin: 0 -0.2rem 0.35rem;
    padding: 0.3rem 0.2rem;
    color: #ccc;
    font-size: 0.8rem;
    text-decoration: underline;
    border-radius: var(--radius-sharp);
  }

  .listing-popup .popup-address:hover {
    color: #fff;
    background: rgb(255 255 255 / 8%);
  }

  .listing-popup .popup-meta {
    margin-bottom: 0.35rem;
    color: #aaa;
  }

  .listing-popup .popup-row {
    margin-bottom: 0.3rem;
    color: #e5e5e5;
  }

  /* Own line, small/muted/uppercase (ROB-160) — previously "Label: value"
     ran together in one plain-colored line, hard to tell apart at a
     glance especially for the long "When" schedule text that wraps.
     Matches the same label/value contrast the /courts/[slug] permalink
     page's <dl> already uses. */
  .listing-popup .popup-label {
    display: block;
    margin-bottom: 0.1rem;
    color: #888;
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .listing-popup .popup-notes {
    margin-top: 0.35rem;
    color: #ccc;
    font-style: italic;
  }

  .listing-popup .popup-link {
    display: inline-block;
    margin-top: 0.5rem;
    color: var(--color-accent);
    font-weight: 600;
    text-decoration: none;
  }

  .listing-popup .popup-votes {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 0.6rem;
    padding-top: 0.5rem;
    border-top: 1px solid #333;
  }

  .listing-popup .popup-votes button {
    padding: 0.15rem 0.45rem;
    font-size: 0.95rem;
    background: rgb(255 255 255 / 8%);
    border: none;
    border-radius: var(--radius-sharp);
    cursor: pointer;
  }

  .listing-popup .popup-activity-date {
    margin-top: 0.25rem;
    color: #888;
    font-size: 0.7rem;
    font-style: italic;
  }

  .listing-popup .popup-votes button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .listing-popup .popup-vote-message {
    color: #ccc;
    font-size: 0.75rem;
  }

  .listing-popup .popup-report-toggle {
    display: block;
    margin-top: 0.5rem;
    padding: 0;
    color: #999;
    font-size: 0.75rem;
    background: none;
    border: none;
    text-decoration: underline;
    cursor: pointer;
  }

  .listing-popup .popup-report-form:not([hidden]) {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-top: 0.4rem;
  }

  /* Honeypot — present in the DOM but invisible/unreachable for a real
     user. Doesn't use [hidden] since some bots specifically skip
     hidden-attribute fields; off-screen positioning catches those too. */
  .listing-popup .popup-honeypot {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    left: -9999px;
  }

  .listing-popup .popup-report-form textarea {
    padding: 0.4rem;
    font-family: inherit;
    font-size: 0.8rem;
    color: #e5e5e5;
    background: rgb(255 255 255 / 8%);
    border: 1px solid #444;
    border-radius: var(--radius-sharp);
  }

  .listing-popup .popup-report-form button[type="submit"] {
    align-self: flex-start;
    padding: 0.35rem 0.85rem;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: white;
    background: var(--color-accent);
    border: none;
    border-radius: var(--radius-sharp);
    cursor: pointer;
    transition: opacity var(--motion-base);
  }

  .listing-popup .popup-report-form button[type="submit"]:hover {
    opacity: 0.88;
  }

  .listing-popup .popup-report-message {
    margin: 0.3rem 0 0;
    color: #ccc;
    font-size: 0.75rem;
  }

  .listing-popup .popup-permalink {
    display: inline-block;
    margin-top: 0.5rem;
    color: #777;
    font-size: 0.7rem;
  }
</style>

<script>
  import L from 'leaflet';
  import 'leaflet.markercluster';
  import { DEFAULT_MAP_CENTER, DEFAULT_MAP_ZOOM, USER_LOCATION_ZOOM, TILE_LAYER_URL, TILE_LAYER_ATTRIBUTION } from '../lib/map/constants';
  import { createVolleyballIcon } from '../lib/map/volleyballIcon';
  import { fetchApprovedListings } from '../lib/listings/fetchApproved';
  import { LISTING_FILTERS_EVENT, defaultListingFilters, listingMatchesFilters } from '../lib/listings/filters';
  import type { ListingFilters } from '../lib/listings/filters';
  import { MAP_PAN_TO_EVENT, LISTING_RESULTS_EVENT, LISTING_SELECT_EVENT } from '../lib/map/events';
  import type { MapPanToDetail, ListingSelectDetail } from '../lib/map/events';
  import { buildListingPopupContent } from '../lib/listings/popup';
  import type { Listing } from '../types/listing';

  // Default zoom control sits top-left, the same corner as the search/
  // filter overlay — moved to bottom-right so they can never collide
  // regardless of viewport width.
  // When the user taps a list card on mobile they're navigated to the
  // listing's permalink; pressing back should restore exactly the map
  // position they left. ListView.astro sets vb_restore_list in
  // sessionStorage before navigating, and saves the last center/zoom
  // here (kept current by scheduleListUpdate below).
  const _rl = sessionStorage.getItem('vb_restore_list') === 'true';
  const _lat = sessionStorage.getItem('vb_map_lat');
  const _lng = sessionStorage.getItem('vb_map_lng');
  const _z   = sessionStorage.getItem('vb_map_zoom');
  const isRestoringState = _rl && _lat !== null && _lng !== null && _z !== null;

  const map = L.map('map', { zoomControl: false }).setView(
    isRestoringState ? [parseFloat(_lat!), parseFloat(_lng!)] : DEFAULT_MAP_CENTER,
    isRestoringState ? parseInt(_z!)                          : DEFAULT_MAP_ZOOM,
  );
  L.control.zoom({ position: 'bottomright' }).addTo(map);

  // iOS Safari's bottom toolbar auto-hides on scroll/interaction after
  // the page has already loaded, growing the visible viewport (and, via
  // the dvh-based height in global.css, the #map container) — but
  // Leaflet only renders tiles for the container size it last measured,
  // so the newly-revealed area stays blank/grey until something tells
  // it to re-measure. Same fix as Header.astro's --header-height sync:
  // watch the container itself rather than guess when this happens.
  //
  // Also re-triggers the list update: updateListResults() bails out
  // silently whenever map.getSize() reads 0×0 (see its own comment
  // below), which real mobile devices can hit for a moment right after
  // load — e.g. the listings fetch resolving and calling it while the
  // viewport/toolbar animation hasn't settled yet. Geolocation's own
  // pan to the visitor's location fires a moveend too, but often
  // *before* the listings have loaded, so that update is empty. Without
  // this, nothing ever calls updateListResults() again until the
  // visitor manually pans (ROB reported: map centers on their location
  // but shows no listings until nudged).
  const mapContainer = document.getElementById('map');
  if (mapContainer) {
    new ResizeObserver(() => {
      map.invalidateSize();
      scheduleListUpdate();
    }).observe(mapContainer);
  }

  // Re-centers on the visitor's own location once geolocation resolves
  // — listings now span more than the original seed region, so the
  // fixed regional default is a worse first view than it used to be
  // for someone outside it. Silently keeps today's default view if
  // permission is denied/unavailable/slow — no fallback UI needed
  // since the map is already usable at that default the instant it
  // loads, geolocation only ever improves on it from there.
  if (!isRestoringState && 'geolocation' in navigator) {
    navigator.geolocation.getCurrentPosition(
      (position) => {
        // animate: false — an animated pan here left Leaflet.markercluster's
        // rendering stuck with no visible icons at the destination on some
        // mobile devices (reported: LA default view shows pins, pans to the
        // visitor's real location, pins vanish until the map is nudged).
        // Same reasoning as the popupopen correction below: landing
        // instantly sidesteps the animation-interrupted-mid-flight class of
        // bug entirely, rather than trying to catch it after the fact.
        // renderMarkers/currentFilters are declared later in this same
        // script, but that's fine — this callback only ever runs once the
        // whole module has finished its synchronous body, well after both
        // are assigned.
        map.setView([position.coords.latitude, position.coords.longitude], USER_LOCATION_ZOOM, { animate: false });
        renderMarkers(currentFilters);
        scheduleListUpdate();
      },
      () => {
        // Permission denied, unavailable, or timed out — no-op.
      },
      { timeout: 8000, maximumAge: 5 * 60 * 1000 },
    );
  }

  L.tileLayer(TILE_LAYER_URL, {
    attribution: TILE_LAYER_ATTRIBUTION,
    maxZoom: 19,
  }).addTo(map);

  // Different orgs sometimes list meetups at the exact same gym/lat-lng.
  // spiderfyOnMaxZoom (on by default, set explicitly here for clarity)
  // is what makes that graceful: clicking a cluster whose members can't
  // be separated by zooming any further fans them out into a small ring
  // instead of just picking one to show, so every listing stays reachable
  // — no de-dup or coordinate-nudging needed on our end.
  const clusterGroup = L.markerClusterGroup({ spiderfyOnMaxZoom: true, zoomToBoundsOnClick: true });
  map.addLayer(clusterGroup);

  let allListings: Listing[] = [];
  let currentFilters: ListingFilters = defaultListingFilters();
  // Looked up when ListView.astro's LISTING_SELECT_EVENT fires — kept in
  // sync with clusterGroup's contents inside renderMarkers below.
  const markersById = new Map<string, L.Marker>();

  function renderMarkers(filters: ListingFilters) {
    clusterGroup.clearLayers();
    markersById.clear();
    for (const listing of allListings) {
      if (!listingMatchesFilters(listing, filters)) continue;
      const marker = L.marker([listing.lat, listing.lng], {
        icon: createVolleyballIcon(listing.type, listing.listing_kind),
        opacity: listing.decayed ? 0.5 : 1,
      });
      // autoPan: false — see the popupopen handler below for why
      // Leaflet's own version of this can't be left enabled (ROB-119).
      marker.bindPopup(buildListingPopupContent(listing), { className: 'volleyball-popup', maxWidth: 260, autoPan: false });
      clusterGroup.addLayer(marker);
      markersById.set(listing.id, marker);
    }
  }

  // The list pane (ROB-131) only makes sense scoped to roughly where
  // someone's actually looking at the map — showing every filter-
  // matched listing nationwide regardless of pan/zoom (the markers
  // themselves still do, that's normal map browsing) made for a list of
  // mostly-irrelevant results whenever the visible area was a single
  // city. Padded rather than the exact viewport (Robert's call) so a
  // listing just off-screen, or panning slightly, doesn't make it
  // flicker in and out of the list.
  const LIST_BOUNDS_PAD_RATIO = 0.5;

  function updateListResults() {
    // Below the 768px breakpoint, ListView.astro's expanded list takes
    // over the full width, which collapses .map-area (flex: 1) and its
    // #map container to 0×0 — the ResizeObserver below still fires
    // invalidateSize() for that, which in turn fires a move event here.
    // getBounds() on a zero-size map returns a degenerate box that
    // contains nothing, which would otherwise wipe the list to empty a
    // moment after it correctly opened (it's not that there's nothing
    // here, the map asking the question just can't see anything right
    // now). Skip and leave the last good list showing instead — the
    // map becomes interactive again, with a real size, the moment List
    // is closed.
    const size = map.getSize();
    if (size.x === 0 || size.y === 0) return;

    const paddedBounds = map.getBounds().pad(LIST_BOUNDS_PAD_RATIO);
    const visible = allListings.filter(
      (listing) => listingMatchesFilters(listing, currentFilters) && paddedBounds.contains([listing.lat, listing.lng]),
    );
    // ListView.astro's list pane renders from this rather than
    // fetching/filtering its own copy of the same data — keeps the list
    // and the map showing the same underlying set, with one fetch.
    window.dispatchEvent(new CustomEvent<Listing[]>(LISTING_RESULTS_EVENT, { detail: visible }));
  }

  // moveend/zoomend already only fire once Leaflet's own pan/zoom
  // animation settles (not continuously during a drag), but a fitBounds
  // or a quick scroll-wheel zoom can still fire a few of these in close
  // succession — debounced so that doesn't mean recomputing the list
  // (a filter() over every listing) several times for one user action.
  let listUpdateTimer: ReturnType<typeof setTimeout> | undefined;
  function scheduleListUpdate() {
    // Keep sessionStorage in sync so ListView.astro can save the current
    // position before navigating to a permalink (back-button restoration).
    const c = map.getCenter();
    sessionStorage.setItem('vb_map_lat', String(c.lat));
    sessionStorage.setItem('vb_map_lng', String(c.lng));
    sessionStorage.setItem('vb_map_zoom', String(map.getZoom()));
    clearTimeout(listUpdateTimer);
    listUpdateTimer = setTimeout(updateListResults, 150);
  }

  map.on('moveend zoomend', scheduleListUpdate);

  // Leaflet's built-in popup autoPan (disabled above, see bindPopup)
  // re-runs on every subsequent map move while a popup is open, not
  // just once at open time — so any manual map.panBy() call made while
  // a popup is showing gets partially fought/undone by Leaflet's own
  // autoPan reacting to that same move (confirmed directly: a manual
  // panBy([0,-220]) only netted +120px of actual on-screen movement
  // with autoPan left on). On iOS this combination of two competing
  // pan systems reliably left the popup positioned off-screen once both
  // settled, reading as the popup just vanishing once the screen
  // stopped moving (ROB-119). Disabling Leaflet's version and doing all
  // of this ourselves — both the map's own edges (its job before) and
  // the .map-controls overlay it doesn't know about (ROB-117) — avoids
  // the conflict entirely instead of trying to out-time it.
  const POPUP_PADDING = 12;

  // Clicking a marker that's part of a cluster (zoomToBoundsOnClick) or
  // a tight group that needs to spiderfy zooms/spreads the map BEFORE
  // the popup opens — and that animation can still be running when
  // 'popupopen' fires. Tracking movestart/zoomstart..moveend/zoomend
  // lets the correction wait that out too, not just a fixed guess at
  // how long any one animation takes.
  let mapIsBusy = false;
  map.on('movestart zoomstart', () => {
    mapIsBusy = true;
  });
  map.on('moveend zoomend', () => {
    mapIsBusy = false;
  });

  map.on('popupopen', (event) => {
    function applyCorrection() {
      const popupEl = event.popup.getElement();
      const controls = document.querySelector('.map-controls');
      if (!popupEl) return;

      const popupRect = popupEl.getBoundingClientRect();
      const mapRect = map.getContainer().getBoundingClientRect();
      const topBound = controls ? Math.max(mapRect.top, controls.getBoundingClientRect().bottom) : mapRect.top;

      // panBy's sign convention, confirmed empirically: a negative
      // component moves page content down/right; positive moves it
      // up/left.
      let dy = 0;
      if (popupRect.top < topBound) {
        dy = -(topBound - popupRect.top + POPUP_PADDING);
      } else if (popupRect.bottom > mapRect.bottom) {
        dy = popupRect.bottom - mapRect.bottom + POPUP_PADDING;
      }

      let dx = 0;
      if (popupRect.left < mapRect.left) {
        dx = -(mapRect.left - popupRect.left + POPUP_PADDING);
      } else if (popupRect.right > mapRect.right) {
        dx = popupRect.right - mapRect.right + POPUP_PADDING;
      }

      if (dx !== 0 || dy !== 0) {
        // animate: false — an animated pan here turned out to depend
        // on requestAnimationFrame to actually progress, and there are
        // real conditions (reduced-motion settings, throttled
        // background tabs, certain mobile browser states) where rAF
        // doesn't reliably drive a transition forward. Since this
        // correction only fires when the popup would otherwise be
        // genuinely unreadable, landing it in the right place
        // instantly and deterministically matters more than animating
        // the hop smoothly.
        map.panBy([dx, dy], { animate: false });
      }
    }

    // A cluster-triggered zoom/spiderfy started before this popup even
    // opened — wait for it to actually finish before measuring, rather
    // than guessing a fixed delay that a slower device or a chained
    // zoom-then-spiderfy could still outlast.
    if (mapIsBusy) {
      map.once('moveend zoomend', () => setTimeout(applyCorrection, 50));
    } else {
      setTimeout(applyCorrection, 50);
    }
  });

  window.addEventListener(LISTING_FILTERS_EVENT, (event) => {
    currentFilters = (event as CustomEvent<ListingFilters>).detail;
    renderMarkers(currentFilters);
    updateListResults();
  });

  window.addEventListener(MAP_PAN_TO_EVENT, (event) => {
    const { boundingBox } = (event as CustomEvent<MapPanToDetail>).detail;
    const [south, north, west, east] = boundingBox;
    map.fitBounds([
      [south, west],
      [north, east],
    ]);
  });

  window.addEventListener(LISTING_SELECT_EVENT, (event) => {
    const { listingId } = (event as CustomEvent<ListingSelectDetail>).detail;
    const marker = markersById.get(listingId);
    if (!marker) return;
    // zoomToShowLayer handles the case where the marker is currently
    // balled up in a cluster — same zoom/spiderfy-then-settle dance the
    // popupopen correction above already waits out, just driven from a
    // list click instead of a direct marker click.
    clusterGroup.zoomToShowLayer(marker, () => marker.openPopup());
  });

  try {
    allListings = await fetchApprovedListings();
    renderMarkers(currentFilters);
    updateListResults();
  } catch (err) {
    console.error(err);
  }
</script>
