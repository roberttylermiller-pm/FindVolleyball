---
const DAYS: Array<{ value: string; label: string }> = [
  { value: 'sun', label: 'Sun' },
  { value: 'mon', label: 'Mon' },
  { value: 'tue', label: 'Tue' },
  { value: 'wed', label: 'Wed' },
  { value: 'thu', label: 'Thu' },
  { value: 'fri', label: 'Fri' },
  { value: 'sat', label: 'Sat' },
];
---

<fieldset class="day-time-picker">
  <legend>Days & Times (optional)</legend>
  <p class="hint">Pick the days it happens — leave all unchecked if there isn't a fixed schedule. Times are optional too.</p>
  <div class="day-chips">
    {
      DAYS.map(({ value, label }) => (
        <label class="day-chip">
          <input type="checkbox" name="days" value={value} data-day={value} />
          <span>{label}</span>
        </label>
      ))
    }
  </div>
  <div class="day-time-rows">
    {
      DAYS.map(({ value, label }) => (
        <div class="day-time-row" data-day-row={value} hidden>
          <span class="day-time-row-label">{label}</span>
          <button type="button" class="time-trigger" data-time-trigger={`start_${value}`} aria-label={`${label} start time`}>
            Set start
          </button>
          <input type="hidden" name={`start_${value}`} />
          <span>to</span>
          <button type="button" class="time-trigger" data-time-trigger={`end_${value}`} aria-label={`${label} end time`}>
            Set end
          </button>
          <input type="hidden" name={`end_${value}`} />
        </div>
      ))
    }
  </div>
</fieldset>

<style>
  .day-time-picker {
    margin: 0;
    padding: 0;
    border: none;

    legend {
      margin-bottom: 0.25rem;
      font-size: 0.875rem;
      font-weight: 600;
    }

    .hint {
      margin: 0 0 0.6rem;
      font-size: 0.8rem;
      color: #666;
    }

    .day-chips {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
    }

    .day-chip {
      position: relative;

      input {
        position: absolute;
        opacity: 0;
        width: 100%;
        height: 100%;
        margin: 0;
        cursor: pointer;
      }

      span {
        display: block;
        padding: 0.4rem 0.75rem;
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--color-text);
        background: white;
        border: 1px solid #ccc;
        border-radius: 999px;
        user-select: none;
      }

      input:checked + span {
        color: white;
        background: var(--color-accent);
        border-color: var(--color-accent);
      }

      input:focus-visible + span {
        outline: 2px solid var(--color-accent);
        outline-offset: 1px;
      }
    }

    .day-time-rows {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
      margin-top: 0.6rem;
    }

    .day-time-row:not([hidden]) {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.4rem 0.6rem;
      background: var(--color-bg);
      border-radius: var(--radius-sharp);

      .day-time-row-label {
        width: 3rem;
        font-size: 0.85rem;
        font-weight: 600;
      }

      .time-trigger {
        padding: 0.3rem 0.6rem;
        font-family: var(--font-mono);
        font-size: 0.75rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: var(--color-text);
        background: white;
        border: 1px solid #ccc;
        border-radius: var(--radius-sharp);
        cursor: pointer;
        transition: opacity var(--motion-base);
      }

      .time-trigger:hover {
        opacity: 0.7;
      }

      span:not(.day-time-row-label) {
        font-size: 0.8rem;
        color: #666;
      }
    }
  }
</style>

<script>
  function formatTime12h(value: string): string {
    const [hourStr, minute] = value.split(':');
    const hour = Number(hourStr);
    const period = hour >= 12 ? 'PM' : 'AM';
    const hour12 = hour % 12 === 0 ? 12 : hour % 12;
    return `${hour12}:${minute} ${period}`;
  }

  function resetTrigger(button: HTMLButtonElement, hiddenInput: HTMLInputElement) {
    hiddenInput.value = '';
    button.textContent = button.dataset.timeTrigger?.startsWith('start_') ? 'Set start' : 'Set end';
  }

  const chipInputs = document.querySelectorAll<HTMLInputElement>('.day-chip input[type="checkbox"]');

  for (const input of chipInputs) {
    const row = document.querySelector<HTMLDivElement>(`[data-day-row="${input.dataset.day}"]`);

    input.addEventListener('change', () => {
      if (!row) return;
      row.hidden = !input.checked;
      if (!input.checked) {
        for (const button of row.querySelectorAll<HTMLButtonElement>('.time-trigger')) {
          const hiddenInput = row.querySelector<HTMLInputElement>(`input[name="${button.dataset.timeTrigger}"]`);
          if (hiddenInput) resetTrigger(button, hiddenInput);
        }
      }
    });
  }

  for (const button of document.querySelectorAll<HTMLButtonElement>('.time-trigger')) {
    button.addEventListener('click', () => {
      const hiddenInput = document.querySelector<HTMLInputElement>(`input[name="${button.dataset.timeTrigger}"]`);
      if (!hiddenInput) return;
      // Looked up lazily rather than cached at module-eval time —
      // ClockTimePicker.astro is mounted after this page's content in
      // BaseLayout, so its script (which sets this) hasn't run yet at
      // the point this script itself first executes.
      (window as unknown as { openClockPicker: (value: string, callback: (value: string) => void) => void }).openClockPicker(hiddenInput.value, (newValue) => {
        if (newValue) {
          hiddenInput.value = newValue;
          button.textContent = formatTime12h(newValue);
        } else {
          resetTrigger(button, hiddenInput);
        }
      });
    });
  }
</script>
