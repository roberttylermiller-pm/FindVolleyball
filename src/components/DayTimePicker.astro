---
const DAYS: Array<{ value: string; label: string }> = [
  { value: 'sun', label: 'Sun' },
  { value: 'mon', label: 'Mon' },
  { value: 'tue', label: 'Tue' },
  { value: 'wed', label: 'Wed' },
  { value: 'thu', label: 'Thu' },
  { value: 'fri', label: 'Fri' },
  { value: 'sat', label: 'Sat' },
];
---

<fieldset class="day-time-picker">
  <legend>Days & Times *</legend>
  <p class="hint">Pick the days it happens — times are optional if it's not at a fixed time.</p>
  <div class="day-chips">
    {
      DAYS.map(({ value, label }) => (
        <label class="day-chip">
          <input type="checkbox" name="days" value={value} data-day={value} />
          <span>{label}</span>
        </label>
      ))
    }
  </div>
  <div class="day-time-rows">
    {
      DAYS.map(({ value, label }) => (
        <div class="day-time-row" data-day-row={value} hidden>
          <span class="day-time-row-label">{label}</span>
          <input type="time" name={`start_${value}`} aria-label={`${label} start time`} />
          <span>to</span>
          <input type="time" name={`end_${value}`} aria-label={`${label} end time`} />
        </div>
      ))
    }
  </div>
</fieldset>

<style>
  .day-time-picker {
    margin: 0;
    padding: 0;
    border: none;

    legend {
      margin-bottom: 0.25rem;
      font-size: 0.875rem;
      font-weight: 600;
    }

    .hint {
      margin: 0 0 0.6rem;
      font-size: 0.8rem;
      color: #666;
    }

    .day-chips {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
    }

    .day-chip {
      position: relative;

      input {
        position: absolute;
        opacity: 0;
        width: 100%;
        height: 100%;
        margin: 0;
        cursor: pointer;
      }

      span {
        display: block;
        padding: 0.4rem 0.75rem;
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--color-text);
        background: white;
        border: 1px solid #ccc;
        border-radius: 999px;
        user-select: none;
      }

      input:checked + span {
        color: white;
        background: var(--color-accent);
        border-color: var(--color-accent);
      }

      input:focus-visible + span {
        outline: 2px solid var(--color-accent);
        outline-offset: 1px;
      }
    }

    .day-time-rows {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
      margin-top: 0.6rem;
    }

    .day-time-row {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.4rem 0.6rem;
      background: var(--color-bg);
      border-radius: 0.375rem;

      .day-time-row-label {
        width: 3rem;
        font-size: 0.85rem;
        font-weight: 600;
      }

      input[type="time"] {
        padding: 0.25rem;
        font-size: 0.875rem;
      }

      span:not(.day-time-row-label) {
        font-size: 0.8rem;
        color: #666;
      }
    }
  }
</style>

<script>
  const chipInputs = document.querySelectorAll<HTMLInputElement>('.day-chip input[type="checkbox"]');

  for (const input of chipInputs) {
    const row = document.querySelector<HTMLDivElement>(`[data-day-row="${input.dataset.day}"]`);

    input.addEventListener('change', () => {
      if (!row) return;
      row.hidden = !input.checked;
      if (!input.checked) {
        for (const timeInput of row.querySelectorAll<HTMLInputElement>('input[type="time"]')) {
          timeInput.value = '';
        }
      }
    });
  }
</script>
