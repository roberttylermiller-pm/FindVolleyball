---
import 'leaflet/dist/leaflet.css';
---

<div class="location-picker">
  <label>
    Address *
    <div class="address-row">
      <input type="text" id="address-input" placeholder="Street address, city, state" required />
      <button type="button" id="find-address-btn">Find</button>
    </div>
  </label>
  <p class="address-confirmation" id="address-confirmation" hidden></p>
  <details id="map-details">
    <summary>Adjust exact pin location (optional)</summary>
    <div id="picker-map"></div>
    <p class="hint">Click the map or drag the pin to fine-tune the exact spot.</p>
  </details>
  <input type="hidden" name="lat" id="lat-input" required />
  <input type="hidden" name="lng" id="lng-input" required />
</div>

<style>
  .location-picker {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;

    label {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
      font-size: 0.875rem;
    }

    .address-row {
      display: flex;
      gap: 0.5rem;

      input {
        flex: 1;
        padding: 0.5rem;
        font-size: 1rem;
        border: 1px solid #ccc;
        border-radius: 0.25rem;
      }

      button {
        padding: 0.5rem 1rem;
        font-size: 0.875rem;
        color: white;
        background: var(--color-accent);
        border: none;
        border-radius: 0.25rem;
        cursor: pointer;
      }
    }

    #picker-map {
      width: 100%;
      height: 16rem;
      margin-top: 0.5rem;
      border-radius: 0.5rem;
    }

    .hint {
      margin: 0.5rem 0 0;
      font-size: 0.8rem;
      color: #666;
    }

    .address-confirmation {
      margin: 0;
      padding: 0.5rem 0.75rem;
      font-size: 0.8rem;
      color: #1a6b2f;
      background: #eaf7ed;
      border-radius: 0.25rem;
    }

    #map-details summary {
      font-size: 0.8rem;
      color: #666;
      cursor: pointer;
    }
  }
</style>

<script>
  import L from 'leaflet';
  import { fixDefaultMarkerIcon } from '../lib/map/fixDefaultIcon';
  import { geocodeLocation, reverseGeocode } from '../lib/geocode';
  import { DEFAULT_MAP_CENTER, DEFAULT_MAP_ZOOM, TILE_LAYER_URL, TILE_LAYER_ATTRIBUTION } from '../lib/map/constants';

  fixDefaultMarkerIcon();

  const map = L.map('picker-map').setView(DEFAULT_MAP_CENTER, DEFAULT_MAP_ZOOM);

  L.tileLayer(TILE_LAYER_URL, {
    attribution: TILE_LAYER_ATTRIBUTION,
    maxZoom: 19,
  }).addTo(map);

  // The map starts inside a closed <details> (and the whole form may
  // itself be [hidden] until auth resolves), so Leaflet often initializes
  // against a zero-size container and renders broken/grey tiles. Rather
  // than track every reason the container could be hidden, just recompute
  // size any time it actually becomes visible.
  const mapContainer = document.getElementById('picker-map')!;
  new ResizeObserver(() => map.invalidateSize()).observe(mapContainer);

  const mapDetails = document.querySelector<HTMLDetailsElement>('#map-details');
  mapDetails?.addEventListener('toggle', () => {
    if (mapDetails.open) map.invalidateSize();
  });

  const latInput = document.querySelector<HTMLInputElement>('#lat-input');
  const lngInput = document.querySelector<HTMLInputElement>('#lng-input');
  const addressConfirmation = document.querySelector<HTMLParagraphElement>('#address-confirmation');

  let marker: L.Marker | null = null;

  function updateInputs(lat: number, lng: number) {
    if (latInput) latInput.value = String(lat);
    if (lngInput) lngInput.value = String(lng);
  }

  function setMarker(lat: number, lng: number) {
    if (marker) {
      marker.setLatLng([lat, lng]);
    } else {
      marker = L.marker([lat, lng], { draggable: true }).addTo(map);
      marker.on('dragend', () => {
        const pos = marker!.getLatLng();
        updateInputs(pos.lat, pos.lng);
      });
    }
    updateInputs(lat, lng);
  }

  map.on('click', (event: L.LeafletMouseEvent) => {
    setMarker(event.latlng.lat, event.latlng.lng);
  });

  const addressInput = document.querySelector<HTMLInputElement>('#address-input');
  const findButton = document.querySelector<HTMLButtonElement>('#find-address-btn');

  async function findAddress() {
    const query = addressInput?.value.trim();
    if (!query) return;

    if (addressConfirmation) addressConfirmation.hidden = true;
    if (findButton) findButton.disabled = true;

    try {
      const result = await geocodeLocation(query);
      if (!result) {
        alert(`Couldn't find "${query}". Try a more specific address, or use "Adjust exact pin location" to drop a pin manually.`);
        return;
      }
      map.setView([result.lat, result.lng], 16);
      setMarker(result.lat, result.lng);

      // Show back the address Nominatim actually matched, so the user
      // can tell at a glance whether it found the right place — without
      // this, a typo'd address could silently resolve to the wrong spot.
      try {
        const confirmed = await reverseGeocode(result.lat, result.lng);
        if (addressConfirmation) {
          const confirmedText = confirmed.address ?? [confirmed.neighborhood ?? confirmed.city].filter(Boolean).join(', ');
          addressConfirmation.textContent = `📍 Set to: ${confirmedText}`;
          addressConfirmation.hidden = false;
        }
      } catch {
        // Forward geocode already succeeded and set the pin — the reverse
        // lookup is just a confirmation nicety, so a failure here isn't
        // worth surfacing as an error to the user.
      }
    } catch (err) {
      console.error(err);
      alert('Address lookup failed. Please try again or use "Adjust exact pin location" to drop a pin manually.');
    } finally {
      if (findButton) findButton.disabled = false;
    }
  }

  findButton?.addEventListener('click', findAddress);

  // Prevent Enter in the address field from submitting the parent
  // submission form — redirect it to the Find action instead.
  addressInput?.addEventListener('keydown', (event) => {
    if (event.key === 'Enter') {
      event.preventDefault();
      findAddress();
    }
  });
</script>
