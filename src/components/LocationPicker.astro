---
import 'leaflet/dist/leaflet.css';
---

<div class="location-picker">
  <label>
    Address *
    <div class="address-field">
      <input
        type="text"
        id="address-input"
        placeholder="Start typing an address..."
        autocomplete="off"
        role="combobox"
        aria-expanded="false"
        aria-autocomplete="list"
        aria-controls="address-suggestions"
        required
      />
      <ul class="address-suggestions" id="address-suggestions" role="listbox" hidden></ul>
    </div>
  </label>
  <p class="address-confirmation" id="address-confirmation" hidden></p>
  <details id="map-details">
    <summary>Adjust exact pin location (optional)</summary>
    <div id="picker-map"></div>
    <p class="hint">Click the map or drag the pin to fine-tune the exact spot.</p>
  </details>
  <input type="hidden" name="lat" id="lat-input" required />
  <input type="hidden" name="lng" id="lng-input" required />
</div>

<style>
  .location-picker {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;

    label {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
      font-size: 0.875rem;
    }

    .address-field {
      position: relative;

      input {
        width: 100%;
        padding: 0.5rem;
        font-size: 1rem;
        border: 1px solid #ccc;
        border-radius: 0.25rem;
      }
    }

    .address-suggestions {
      position: absolute;
      z-index: 10;
      top: calc(100% + 0.25rem);
      left: 0;
      right: 0;
      margin: 0;
      padding: 0.25rem;
      list-style: none;
      background: white;
      border: 1px solid #ccc;
      border-radius: 0.25rem;
      box-shadow: 0 4px 12px rgb(0 0 0 / 12%);

      li {
        padding: 0.5rem 0.6rem;
        font-size: 0.875rem;
        border-radius: 0.2rem;
        cursor: pointer;
      }

      li:hover,
      li.highlighted {
        background: rgb(255 122 0 / 10%);
      }
    }

    #picker-map {
      width: 100%;
      height: 16rem;
      margin-top: 0.5rem;
      border-radius: 0.5rem;
    }

    .hint {
      margin: 0.5rem 0 0;
      font-size: 0.8rem;
      color: #666;
    }

    .address-confirmation {
      margin: 0;
      padding: 0.5rem 0.75rem;
      font-size: 0.8rem;
      color: #1a6b2f;
      background: #eaf7ed;
      border-radius: 0.25rem;
    }

    #map-details summary {
      font-size: 0.8rem;
      color: #666;
      cursor: pointer;
    }
  }
</style>

<script>
  import L from 'leaflet';
  import { fixDefaultMarkerIcon } from '../lib/map/fixDefaultIcon';
  import { geocodeSuggestions, type AddressSuggestion } from '../lib/geocode';
  import { DEFAULT_MAP_CENTER, DEFAULT_MAP_ZOOM, TILE_LAYER_URL, TILE_LAYER_ATTRIBUTION } from '../lib/map/constants';

  fixDefaultMarkerIcon();

  const map = L.map('picker-map').setView(DEFAULT_MAP_CENTER, DEFAULT_MAP_ZOOM);

  L.tileLayer(TILE_LAYER_URL, {
    attribution: TILE_LAYER_ATTRIBUTION,
    maxZoom: 19,
  }).addTo(map);

  // The map starts inside a closed <details> (and the whole form may
  // itself be [hidden] until auth resolves), so Leaflet often initializes
  // against a zero-size container and renders broken/grey tiles. Rather
  // than track every reason the container could be hidden, just recompute
  // size any time it actually becomes visible.
  const mapContainer = document.getElementById('picker-map')!;
  new ResizeObserver(() => map.invalidateSize()).observe(mapContainer);

  const mapDetails = document.querySelector<HTMLDetailsElement>('#map-details');
  mapDetails?.addEventListener('toggle', () => {
    if (mapDetails.open) map.invalidateSize();
  });

  const latInput = document.querySelector<HTMLInputElement>('#lat-input');
  const lngInput = document.querySelector<HTMLInputElement>('#lng-input');
  const addressConfirmation = document.querySelector<HTMLParagraphElement>('#address-confirmation');

  let marker: L.Marker | null = null;

  function updateInputs(lat: number, lng: number) {
    if (latInput) latInput.value = String(lat);
    if (lngInput) lngInput.value = String(lng);
  }

  function setMarker(lat: number, lng: number) {
    if (marker) {
      marker.setLatLng([lat, lng]);
    } else {
      marker = L.marker([lat, lng], { draggable: true }).addTo(map);
      marker.on('dragend', () => {
        const pos = marker!.getLatLng();
        updateInputs(pos.lat, pos.lng);
      });
    }
    updateInputs(lat, lng);
  }

  map.on('click', (event: L.LeafletMouseEvent) => {
    setMarker(event.latlng.lat, event.latlng.lng);
  });

  const addressInput = document.querySelector<HTMLInputElement>('#address-input');
  const suggestionsList = document.querySelector<HTMLUListElement>('#address-suggestions');

  let suggestions: AddressSuggestion[] = [];
  let highlightedIndex = -1;
  // Discards a response if a newer keystroke has already fired another
  // request by the time it comes back — typing fast can otherwise show
  // suggestions for an address the user has since typed past.
  let latestRequestId = 0;
  let debounceTimer: ReturnType<typeof setTimeout> | undefined;

  function pickSuggestion(suggestion: AddressSuggestion) {
    if (addressInput) addressInput.value = suggestion.displayName;
    map.setView([suggestion.lat, suggestion.lng], 16);
    setMarker(suggestion.lat, suggestion.lng);

    if (addressConfirmation) {
      addressConfirmation.textContent = `📍 Set to: ${suggestion.displayName}`;
      addressConfirmation.hidden = false;
    }

    closeSuggestions();
  }

  function renderSuggestions() {
    if (!suggestionsList) return;

    if (suggestions.length === 0) {
      closeSuggestions();
      return;
    }

    suggestionsList.innerHTML = suggestions
      .map(
        (suggestion, index) => `
          <li role="option" id="address-option-${index}" aria-selected="${index === highlightedIndex}"
              class="${index === highlightedIndex ? 'highlighted' : ''}" data-index="${index}">
            ${suggestion.displayName}
          </li>
        `,
      )
      .join('');
    suggestionsList.hidden = false;
    addressInput?.setAttribute('aria-expanded', 'true');

    for (const li of suggestionsList.querySelectorAll<HTMLLIElement>('li')) {
      li.addEventListener('click', () => {
        const index = Number(li.dataset.index);
        const suggestion = suggestions[index];
        if (suggestion) pickSuggestion(suggestion);
      });
    }
  }

  function closeSuggestions() {
    suggestions = [];
    highlightedIndex = -1;
    if (suggestionsList) {
      suggestionsList.hidden = true;
      suggestionsList.innerHTML = '';
    }
    addressInput?.setAttribute('aria-expanded', 'false');
    addressInput?.removeAttribute('aria-activedescendant');
  }

  addressInput?.addEventListener('input', () => {
    const query = addressInput.value.trim();
    if (addressConfirmation) addressConfirmation.hidden = true;

    if (debounceTimer) clearTimeout(debounceTimer);

    if (query.length < 3) {
      closeSuggestions();
      return;
    }

    debounceTimer = setTimeout(async () => {
      const requestId = ++latestRequestId;
      try {
        // Biases results toward wherever the picker map is currently
        // centered (starts at DEFAULT_MAP_CENTER, moves if a suggestion
        // is picked or the pin is dropped/dragged) — without this,
        // partial queries like a bare street name return scattered
        // global matches instead of nearby ones.
        const center = map.getCenter();
        const results = await geocodeSuggestions(query, center.lat, center.lng);
        if (requestId !== latestRequestId) return; // a newer query has since superseded this one
        suggestions = results;
        highlightedIndex = -1;
        renderSuggestions();
      } catch (err) {
        console.error(err);
      }
      // ~1 request/second is Nominatim's usage policy ceiling for
      // anonymous use — 400ms of debounce keeps normal typing well
      // under that without feeling sluggish.
    }, 400);
  });

  addressInput?.addEventListener('keydown', (event) => {
    if (suggestions.length === 0) return;

    if (event.key === 'ArrowDown') {
      event.preventDefault();
      highlightedIndex = (highlightedIndex + 1) % suggestions.length;
      renderSuggestions();
    } else if (event.key === 'ArrowUp') {
      event.preventDefault();
      highlightedIndex = (highlightedIndex - 1 + suggestions.length) % suggestions.length;
      renderSuggestions();
    } else if (event.key === 'Enter') {
      // Prevents Enter from submitting the parent submission form —
      // selects the highlighted suggestion (or the first one) instead.
      event.preventDefault();
      const suggestion = suggestions[highlightedIndex >= 0 ? highlightedIndex : 0];
      if (suggestion) pickSuggestion(suggestion);
    } else if (event.key === 'Escape') {
      closeSuggestions();
    }
  });

  document.addEventListener('click', (event) => {
    if (!(event.target instanceof Node)) return;
    if (addressInput?.contains(event.target) || suggestionsList?.contains(event.target)) return;
    closeSuggestions();
  });
</script>
