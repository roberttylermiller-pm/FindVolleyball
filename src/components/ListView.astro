---
---

<aside id="list-panel" class="list-panel" aria-label="Listings list view">
  <div class="list-panel-header">
    <h2>Listings</h2>
    <span id="list-count" class="list-count"></span>
  </div>
  <div id="list-results"></div>
</aside>

<style>
  .list-panel {
    width: 0;
    height: 100%;
    overflow-y: auto;
    flex-shrink: 0;
    background: white;
    border-left: 1px solid #e5e5e5;
    transition: width 0.2s ease;
  }

  .list-panel.expanded {
    width: 24rem;
  }

  .list-panel-header {
    position: sticky;
    top: 0;
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    padding: 5.5rem 1rem 0.75rem;
    background: white;

    h2 {
      margin: 0;
      font-size: 1rem;
    }
  }

  .list-count {
    font-size: 0.8rem;
    color: #888;
  }

  #list-results {
    padding: 0 1rem 1rem;
  }

  .list-empty {
    color: #888;
    font-size: 0.875rem;
  }

  .list-item {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    width: 100%;
    padding: 0.6rem 0.7rem;
    margin-bottom: 0.5rem;
    text-align: left;
    background: var(--color-bg);
    border: 1px solid #e5e5e5;
    border-radius: 0.4rem;
    cursor: pointer;
  }

  .list-item:hover {
    border-color: var(--color-accent);
  }

  .list-item-kind {
    align-self: flex-start;
    padding: 0.05rem 0.4rem;
    font-size: 0.65rem;
    font-weight: 600;
    color: #1c1c1e;
    background: #8ab4f8;
    border-radius: 0.25rem;
  }

  .list-item[data-kind="tournament"] .list-item-kind {
    background: #ffd166;
  }

  .list-item[data-kind="league"] .list-item-kind {
    background: #8bd3a0;
  }

  .list-item-name {
    font-size: 0.9rem;
  }

  .list-item-meta,
  .list-item-schedule {
    font-size: 0.78rem;
    color: #666;
  }

  @media (max-width: 767px) {
    .list-panel.expanded {
      width: 100%;
    }
  }
</style>

<script>
  import { LISTING_RESULTS_EVENT, LISTING_SELECT_EVENT } from '../lib/map/events';
  import type { ListingSelectDetail } from '../lib/map/events';
  import { formatListingTypeLabel } from '../lib/listings/typeLabel';
  import { formatListingKindLabel } from '../lib/listings/kindLabel';
  import { formatDateRange } from '../lib/listings/formatDateRange';
  import { formatDayTime } from '../lib/listings/formatDayTime';
  import type { Listing } from '../types/listing';

  const resultsEl = document.querySelector<HTMLDivElement>('#list-results');
  const countEl = document.querySelector<HTMLSpanElement>('#list-count');

  function scheduleLine(listing: Listing): string {
    if (listing.start_date && listing.end_date) return formatDateRange(listing.start_date, listing.end_date);
    if (listing.days_times.length > 0) return listing.days_times.map(formatDayTime).join(', ');
    return '';
  }

  function render(listings: Listing[]) {
    if (!resultsEl) return;
    if (countEl) countEl.textContent = `${listings.length} listing${listings.length === 1 ? '' : 's'}`;

    if (listings.length === 0) {
      resultsEl.innerHTML = '<p class="list-empty">No listings match the current filters.</p>';
      return;
    }

    // Alphabetical rather than the map's draw order — easier to scan a
    // list of names than to follow whatever order markers happened to
    // load in.
    const sorted = [...listings].sort((a, b) =>
      (a.name ?? `${a.type} listing`).localeCompare(b.name ?? `${b.type} listing`),
    );

    resultsEl.innerHTML = sorted
      .map(
        (listing) => `
        <button type="button" class="list-item" data-id="${listing.id}" data-kind="${listing.listing_kind}">
          <span class="list-item-kind">${formatListingKindLabel(listing.listing_kind)}</span>
          <strong class="list-item-name">${listing.name ?? `${formatListingTypeLabel(listing.type).toLowerCase()} volleyball`}</strong>
          <span class="list-item-meta">${formatListingTypeLabel(listing.type)}${listing.city ? ` · ${listing.city}` : ''}</span>
          ${scheduleLine(listing) ? `<span class="list-item-schedule">${scheduleLine(listing)}</span>` : ''}
        </button>`,
      )
      .join('');
  }

  window.addEventListener(LISTING_RESULTS_EVENT, (event) => {
    render((event as CustomEvent<Listing[]>).detail);
  });

  resultsEl?.addEventListener('click', (event) => {
    const button = (event.target as HTMLElement).closest<HTMLButtonElement>('.list-item');
    if (!button?.dataset.id) return;
    window.dispatchEvent(
      new CustomEvent<ListingSelectDetail>(LISTING_SELECT_EVENT, { detail: { listingId: button.dataset.id } }),
    );
  });
</script>
