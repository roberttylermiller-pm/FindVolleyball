---
import { Image } from 'astro:assets';
import logo from '../assets/logo.png';
---

<header class="site-header">
  <a href="/" class="brand">
    <Image src={logo} alt="Find Volleyball" width={28} height={28} class="brand-mark" />
    <span class="brand-wordmark">Find Volleyball</span>
  </a>
  <div class="header-actions">
    <nav class="nav-links">
      <a href="/about">About</a>
      <a href="/privacy">Privacy</a>
      <a href="/terms">Terms</a>
    </nav>
    <a
      class="coffee-link"
      href="https://buymeacoffee.com/findvolleyball"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Buy me a coffee"
      title="Buy me a coffee"
    >
      ☕
    </a>
    <button id="feedback-open-btn" type="button" class="feedback-open-btn" title="Submit feedback">
      Feedback
    </button>
    <a id="add-entry-btn" class="add-entry-btn" href="/login?redirect=/submit">Add Listing</a>
    <div id="auth-status" class="auth-status">
      <a href="/login">Sign in</a>
      <a href="/signup">Sign up</a>
    </div>
  </div>
</header>

<style>
  .site-header {
    display: flex;
    flex-shrink: 0;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    height: var(--header-height);
    padding: 0 1.5rem;
    background: white;
    border-bottom: 1px solid #e5e5e5;

    /* On narrow phones the logo keeps its own row and everything else
       (nav links, coffee, Add Listing, sign in/up) wraps to a second,
       right-aligned row instead of overflowing past Sign in/Sign up. */
    @media (max-width: 480px) {
      height: auto;
      padding: 0.6rem 1rem;
      row-gap: 0.4rem;

      .header-actions {
        flex-basis: 100%;
        flex-wrap: wrap;
        justify-content: flex-end;
        gap: 0.75rem;
      }
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 0.45rem;
      color: var(--color-text);
      text-decoration: none;
      font-weight: 700;
    }

    .brand-mark {
      flex-shrink: 0;
    }

    .brand-wordmark {
      font-family: "Sirin Stencil", var(--font-sans);
      /* Sirin Stencil only ships a single (regular) weight — forcing
         bold would just trigger the browser's synthesized-bold
         distortion instead of an actual bold cut of the typeface. */
      font-weight: 400;
      font-size: 1.05rem;
      letter-spacing: 0.01em;
    }

    .header-actions {
      display: flex;
      align-items: center;
      gap: 1.25rem;
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 0.9rem;
      font-size: 0.8rem;

      a {
        color: #666;
        text-decoration: none;
      }

      a:hover {
        text-decoration: underline;
      }
    }

    .coffee-link {
      font-size: 1.2rem;
      line-height: 1;
      text-decoration: none;
      filter: grayscale(1);
      opacity: 0.7;
      transition: filter 0.15s, opacity 0.15s;
    }

    .coffee-link:hover {
      filter: none;
      opacity: 1;
    }

    .feedback-open-btn {
      padding: 0;
      font-family: inherit;
      font-size: 0.8rem;
      color: #666;
      background: none;
      border: none;
      cursor: pointer;
    }

    .feedback-open-btn:hover {
      text-decoration: underline;
    }

    .add-entry-btn {
      padding: 0.4rem 0.9rem;
      font-size: 0.8rem;
      font-weight: 600;
      color: white;
      background: var(--color-accent);
      border-radius: 0.3rem;
      text-decoration: none;
    }

    .auth-status {
      display: flex;
      align-items: center;
      gap: 1rem;
      font-size: 0.875rem;

      a,
      button {
        font-family: inherit;
        font-size: inherit;
        color: var(--color-text);
        text-decoration: none;
        background: none;
        border: none;
        cursor: pointer;
      }
    }
  }
</style>

<script>
  import { supabase } from '../lib/supabase/client';

  const container = document.querySelector<HTMLDivElement>('#auth-status');
  const addEntryBtn = document.querySelector<HTMLAnchorElement>('#add-entry-btn');

  function renderSignedOut() {
    if (!container) return;
    container.innerHTML = '<a href="/login">Sign in</a><a href="/signup">Sign up</a>';
  }

  function renderSignedIn(email: string) {
    if (!container) return;
    container.innerHTML = `<span>${email}</span><button id="sign-out-btn">Sign out</button>`;
    container.querySelector('#sign-out-btn')?.addEventListener('click', () => {
      supabase.auth.signOut();
    });
  }

  // onAuthStateChange fires immediately on subscribe with the current
  // session (INITIAL_SESSION), so this also covers the initial render —
  // no separate getSession() call needed.
  supabase.auth.onAuthStateChange((_event, session) => {
    const email = session?.user.email;
    if (addEntryBtn) {
      addEntryBtn.href = email ? '/submit' : '/login?redirect=/submit';
    }
    if (email) {
      renderSignedIn(email);
    } else {
      renderSignedOut();
    }
  });
</script>
