---
import { Image } from 'astro:assets';
import logo from '../assets/logo.png';
---

<header class="site-header">
  <a href="/" class="brand">
    <Image src={logo} alt="Find Volleyball" width={28} height={28} class="brand-mark" />
    <span class="brand-wordmark">Find Volleyball</span>
  </a>
  <div class="header-primary">
    <a id="add-entry-btn" class="add-entry-btn" href="/login?redirect=/submit">Add Listing</a>
    <div id="auth-status" class="auth-status">
      <a href="/login">Sign in</a>
      <a href="/signup">Sign up</a>
    </div>
    <!-- Only shown on narrow screens (ROB-120) — on wider ones
         .header-secondary is always visible and this stays hidden. -->
    <button
      id="header-menu-toggle"
      type="button"
      class="header-menu-toggle"
      aria-expanded="false"
      aria-controls="header-secondary"
      aria-label="More links"
    >
      ☰
    </button>
  </div>
  <nav id="header-secondary" class="header-secondary collapsed">
    <a href="/about">About</a>
    <a href="/privacy">Privacy</a>
    <a href="/terms">Terms</a>
    <a
      class="coffee-link"
      href="https://buymeacoffee.com/findvolleyball"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Buy me a coffee"
      title="Buy me a coffee"
    >
      ☕
    </a>
    <button id="feedback-open-btn" type="button" class="feedback-open-btn" title="Submit feedback">
      Feedback
    </button>
  </nav>
</header>

<style>
  .site-header {
    display: flex;
    flex-shrink: 0;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    height: var(--header-height);
    padding: 0 1.5rem;
    background: white;
    border-bottom: 1px solid #e5e5e5;

    .brand {
      display: flex;
      align-items: center;
      gap: 0.45rem;
      color: var(--color-text);
      text-decoration: none;
      font-weight: 700;
    }

    .brand-mark {
      flex-shrink: 0;
    }

    .brand-wordmark {
      /* Bricolage Grotesque (ROB-169), replacing Sirin Stencil (ROB-81). */
      font-family: var(--font-display);
      font-weight: 700;
      font-size: 1.1rem;
      letter-spacing: -0.01em;
    }

    .header-primary {
      display: flex;
      align-items: center;
      gap: 1.25rem;
    }

    .header-secondary {
      display: flex;
      align-items: center;
      gap: 0.9rem;
      font-size: 0.8rem;

      a {
        color: #666;
        text-decoration: none;
      }

      a:hover {
        text-decoration: underline;
      }
    }

    .header-menu-toggle {
      display: none;
      align-items: center;
      justify-content: center;
      width: 1.75rem;
      height: 1.75rem;
      padding: 0;
      font-size: 1.1rem;
      line-height: 1;
      color: var(--color-text);
      background: none;
      border: none;
      cursor: pointer;
    }

    .coffee-link {
      font-size: 1.2rem;
      line-height: 1;
      text-decoration: none;
      filter: grayscale(1);
      opacity: 0.7;
      transition: filter 0.15s, opacity 0.15s;
    }

    .coffee-link:hover {
      filter: none;
      opacity: 1;
    }

    .feedback-open-btn {
      padding: 0;
      font-family: inherit;
      font-size: 0.8rem;
      color: #666;
      background: none;
      border: none;
      cursor: pointer;
    }

    .feedback-open-btn:hover {
      text-decoration: underline;
    }

    .add-entry-btn {
      padding: 0.5rem 1rem;
      font-family: var(--font-mono);
      font-size: 0.72rem;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: white;
      background: var(--color-accent);
      border-radius: var(--radius-sharp);
      text-decoration: none;
      transition: opacity var(--motion-base);
    }

    .add-entry-btn:hover {
      opacity: 0.88;
    }

    .add-entry-btn:active {
      transform: scale(0.97);
      transition-duration: var(--motion-fast);
    }

    .auth-status {
      display: flex;
      align-items: center;
      gap: 1rem;
      font-size: 0.875rem;

      a,
      button {
        font-family: inherit;
        font-size: inherit;
        color: var(--color-text);
        text-decoration: none;
        background: none;
        border: none;
        cursor: pointer;
      }
    }

    /* On narrow phones, .header-secondary (About/Privacy/Terms, coffee,
       Feedback) collapses behind the hamburger toggle by default
       instead of always wrapping to a second row (ROB-120) — a smaller
       screen was losing a meaningful chunk of map height to the header
       before this. Add Listing and Sign in/up stay visible; only the
       toggle itself appears at this width. Placed after the base rules
       above (not interleaved with them) so these overrides reliably
       win the cascade regardless of declaration order elsewhere. */
    @media (max-width: 480px) {
      height: auto;
      padding: 0.6rem 1rem;
      row-gap: 0.4rem;

      /* Logo image alone (still a link to home) — the "Find Volleyball"
         wordmark was the difference between the brand and the primary
         actions (Add Listing, Sign in/up, hamburger) fitting on one
         row versus wrapping to two on a smaller phone. */
      .brand-wordmark {
        display: none;
      }

      .header-primary {
        gap: 0.6rem;
      }

      .header-secondary {
        flex-basis: 100%;
        flex-wrap: wrap;
        justify-content: flex-end;
        gap: 0.75rem;

        &.collapsed {
          display: none;
        }
      }

      .header-menu-toggle {
        display: flex;
      }
    }
  }
</style>

<script>
  import { supabase } from '../lib/supabase/client';

  const container = document.querySelector<HTMLDivElement>('#auth-status');
  const addEntryBtn = document.querySelector<HTMLAnchorElement>('#add-entry-btn');

  const menuToggle = document.querySelector<HTMLButtonElement>('#header-menu-toggle');
  const secondaryNav = document.querySelector<HTMLElement>('#header-secondary');
  menuToggle?.addEventListener('click', () => {
    const expanded = secondaryNav?.classList.toggle('collapsed') === false;
    menuToggle.setAttribute('aria-expanded', String(expanded));
  });

  // --header-height drives where the map page's fixed-position search/
  // filter overlay sits (see index.astro) — kept in sync with the
  // header's actual rendered height via ResizeObserver rather than
  // hardcoded per-breakpoint values, so it stays correct whether the
  // header is its normal single row or briefly two rows while
  // .header-secondary is expanded on a narrow screen (ROB-120).
  const header = document.querySelector<HTMLElement>('.site-header');
  if (header) {
    const syncHeaderHeight = () => {
      document.documentElement.style.setProperty('--header-height', `${header.offsetHeight}px`);
    };
    new ResizeObserver(syncHeaderHeight).observe(header);
    syncHeaderHeight();
  }

  function renderSignedOut() {
    if (!container) return;
    container.innerHTML = '<a href="/login">Sign in</a><a href="/signup">Sign up</a>';
  }

  function renderSignedIn(email: string) {
    if (!container) return;
    // The email used to show inline next to "Sign out" — on a narrow
    // phone a long address (e.g. a full Gmail address) was wide enough
    // on its own to push the header back to two rows despite the other
    // space-saving changes here. Kept as a title tooltip (so it's still
    // there for anyone who wants to confirm which account) rather than
    // dropped entirely.
    container.innerHTML = `<button id="sign-out-btn" title="Signed in as ${email}">Sign out</button>`;
    container.querySelector('#sign-out-btn')?.addEventListener('click', () => {
      supabase.auth.signOut();
    });
  }

  // onAuthStateChange fires immediately on subscribe with the current
  // session (INITIAL_SESSION), so this also covers the initial render —
  // no separate getSession() call needed.
  supabase.auth.onAuthStateChange((_event, session) => {
    const email = session?.user.email;
    if (addEntryBtn) {
      addEntryBtn.href = email ? '/submit' : '/login?redirect=/submit';
    }
    if (email) {
      renderSignedIn(email);
    } else {
      renderSignedOut();
    }
  });
</script>
