<header class="site-header">
  <a href="/" class="brand">
    <svg class="brand-mark" width="26" height="26" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <circle cx="12" cy="12" r="10" stroke="var(--color-accent)" stroke-width="1.6" />
      <path d="M7 4.5Q11 6 13.7 10.7" stroke="var(--color-accent)" stroke-width="1.3" stroke-linecap="round" />
      <path d="M19.3 9.3Q18 13.5 13.1 16" stroke="var(--color-accent)" stroke-width="1.3" stroke-linecap="round" />
      <path d="M11 19.3Q7 18 4.3 13.1" stroke="var(--color-accent)" stroke-width="1.3" stroke-linecap="round" />
    </svg>
    <span class="brand-wordmark">FindVolleyball</span>
  </a>
  <div class="header-actions">
    <a id="add-entry-btn" class="add-entry-btn" href="/login?redirect=/submit">Add Entry</a>
    <div id="auth-status" class="auth-status">
      <a href="/login">Sign in</a>
      <a href="/signup">Sign up</a>
    </div>
  </div>
</header>

<style>
  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: var(--header-height);
    padding: 0 1.5rem;
    background: white;
    border-bottom: 1px solid #e5e5e5;

    .brand {
      display: flex;
      align-items: center;
      gap: 0.45rem;
      color: var(--color-text);
      text-decoration: none;
      font-weight: 700;
    }

    .brand-mark {
      flex-shrink: 0;
    }

    .header-actions {
      display: flex;
      align-items: center;
      gap: 1.25rem;
    }

    .add-entry-btn {
      padding: 0.4rem 0.9rem;
      font-size: 0.8rem;
      font-weight: 600;
      color: white;
      background: var(--color-accent);
      border-radius: 0.3rem;
      text-decoration: none;
    }

    .auth-status {
      display: flex;
      align-items: center;
      gap: 1rem;
      font-size: 0.875rem;

      a,
      button {
        font-family: inherit;
        font-size: inherit;
        color: var(--color-text);
        text-decoration: none;
        background: none;
        border: none;
        cursor: pointer;
      }
    }
  }
</style>

<script>
  import { supabase } from '../lib/supabase/client';

  const container = document.querySelector<HTMLDivElement>('#auth-status');
  const addEntryBtn = document.querySelector<HTMLAnchorElement>('#add-entry-btn');

  function renderSignedOut() {
    if (!container) return;
    container.innerHTML = '<a href="/login">Sign in</a><a href="/signup">Sign up</a>';
  }

  function renderSignedIn(email: string) {
    if (!container) return;
    container.innerHTML = `<span>${email}</span><button id="sign-out-btn">Sign out</button>`;
    container.querySelector('#sign-out-btn')?.addEventListener('click', () => {
      supabase.auth.signOut();
    });
  }

  // onAuthStateChange fires immediately on subscribe with the current
  // session (INITIAL_SESSION), so this also covers the initial render —
  // no separate getSession() call needed.
  supabase.auth.onAuthStateChange((_event, session) => {
    const email = session?.user.email;
    if (addEntryBtn) {
      addEntryBtn.href = email ? '/submit' : '/login?redirect=/submit';
    }
    if (email) {
      renderSignedIn(email);
    } else {
      renderSignedOut();
    }
  });
</script>
