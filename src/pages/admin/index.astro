---
import BaseLayout from '../../layouts/BaseLayout.astro';

const DAYS: Array<{ value: string; label: string }> = [
  { value: 'sun', label: 'Sun' },
  { value: 'mon', label: 'Mon' },
  { value: 'tue', label: 'Tue' },
  { value: 'wed', label: 'Wed' },
  { value: 'thu', label: 'Thu' },
  { value: 'fri', label: 'Fri' },
  { value: 'sat', label: 'Sat' },
];
---

<BaseLayout title="Admin | FindVolleyball">
  <main class="admin-page">
    <h1>Admin Dashboard</h1>
    <p id="status-message" role="status"></p>

    <section id="admin-content" hidden>
      <div class="admin-tabs" role="tablist">
        <button type="button" class="admin-tab" data-kind="recurring" role="tab" aria-selected="true">Recurring</button>
        <button type="button" class="admin-tab" data-kind="tournament" role="tab" aria-selected="false">Tournament</button>
        <button type="button" class="admin-tab" data-kind="league" role="tab" aria-selected="false">League</button>
      </div>

      <section>
        <h2>Pending review</h2>
        <div id="pending-list"></div>
      </section>

      <section>
        <h2>Reports</h2>
        <div id="reports-list"></div>
      </section>

      <section>
        <div class="section-header">
          <h2>All listings</h2>
          <label class="sort-label">
            Sort by
            <select id="all-listings-sort">
              <option value="date-desc">Date added (newest first)</option>
              <option value="date-asc">Date added (oldest first)</option>
              <option value="alpha">Alphabetical</option>
              <option value="upvoted">Last upvoted</option>
            </select>
          </label>
        </div>
        <div id="all-listings-list"></div>
      </section>
    </section>
  </main>

  <dialog id="edit-dialog">
    <form id="edit-form">
      <h2>Edit listing</h2>

      <label>
        Name
        <input type="text" name="name" />
      </label>

      <div class="field-row">
        <fieldset>
          <legend>Type</legend>
          <label><input type="radio" name="type" value="indoor" /> Indoor</label>
          <label><input type="radio" name="type" value="grass" /> Grass</label>
          <label><input type="radio" name="type" value="beach" /> Sand</label>
        </fieldset>

        <fieldset>
          <legend>Cost</legend>
          <label><input type="radio" name="cost" value="" /> Not specified</label>
          <label><input type="radio" name="cost" value="free" /> Free</label>
          <label><input type="radio" name="cost" value="paid" /> Paid</label>
        </fieldset>

        <fieldset>
          <legend>Visibility</legend>
          <label><input type="radio" name="visibility" value="public" /> Public</label>
          <label><input type="radio" name="visibility" value="private" /> Private</label>
        </fieldset>
      </div>

      <div class="field-row">
        <fieldset>
          <legend>Kind</legend>
          <label><input type="radio" name="listing_kind" value="recurring" /> Recurring</label>
          <label><input type="radio" name="listing_kind" value="tournament" /> Tournament</label>
          <label><input type="radio" name="listing_kind" value="league" /> League</label>
        </fieldset>
        <div class="field-row kind-conditional" data-kind-show="tournament,league">
          <label>
            Start date
            <input type="date" name="start_date" />
          </label>
          <label>
            End date
            <input type="date" name="end_date" />
          </label>
        </div>
      </div>

      <div class="field-row">
        <label>
          Latitude
          <input type="number" name="lat" step="any" required />
        </label>
        <label>
          Longitude
          <input type="number" name="lng" step="any" required />
        </label>
      </div>

      <label>
        Address as entered by submitter
        <input type="text" name="submitted_address" />
        <span class="field-hint">Raw text the submitter typed — preserved even if geocoding below failed or picked the wrong spot.</span>
      </label>

      <label>
        Street address (geocoded)
        <input type="text" name="address" />
      </label>

      <label>
        Google Maps link (optional)
        <input type="text" name="google_maps_url" placeholder="https://www.google.com/maps/place/..." />
        <span class="field-hint">If set, the address link on the listing page uses this directly instead of a search query.</span>
      </label>

      <div class="decode-maps-row">
        <button type="button" id="decode-maps-btn">Decode coordinates from Maps link</button>
        <span id="decode-maps-message" role="status"></span>
      </div>

      <div class="field-row">
        <label>
          City
          <input type="text" name="city" />
        </label>
        <label>
          Neighborhood
          <input type="text" name="neighborhood" />
        </label>
      </div>

      <fieldset class="day-time-edit kind-conditional" data-kind-show="recurring,league">
        <legend>Days & Times</legend>
        <div class="day-chips">
          {
            DAYS.map(({ value, label }) => (
              <label class="day-chip">
                <input type="checkbox" name="days" value={value} data-day={value} />
                <span>{label}</span>
              </label>
            ))
          }
        </div>
        <div class="day-time-rows">
          {
            DAYS.map(({ value, label }) => (
              <div class="day-time-row" data-day-row={value} hidden>
                <span class="day-time-row-label">{label}</span>
                <button type="button" class="time-trigger" data-time-trigger={`start_${value}`} aria-label={`${label} start time`}>
                  Set start
                </button>
                <input type="hidden" name={`start_${value}`} />
                <span>to</span>
                <button type="button" class="time-trigger" data-time-trigger={`end_${value}`} aria-label={`${label} end time`}>
                  Set end
                </button>
                <input type="hidden" name={`end_${value}`} />
              </div>
            ))
          }
        </div>
      </fieldset>

      <div class="field-row">
        <fieldset>
          <legend>Sign-up required</legend>
          <label><input type="radio" name="signup_required" value="" /> Not specified</label>
          <label><input type="radio" name="signup_required" value="yes" /> Yes</label>
          <label><input type="radio" name="signup_required" value="no" /> No</label>
        </fieldset>

        <div class="field-row kind-conditional" data-kind-show="recurring">
          <fieldset>
            <legend>Equipment supplied</legend>
            <label><input type="radio" name="equipment_supplied" value="" /> Not specified</label>
            <label><input type="radio" name="equipment_supplied" value="yes" /> Yes</label>
            <label><input type="radio" name="equipment_supplied" value="no" /> No</label>
          </fieldset>

          <fieldset>
            <legend>Team required</legend>
            <label><input type="radio" name="team_required" value="" /> Not specified</label>
            <label><input type="radio" name="team_required" value="yes" /> Yes</label>
            <label><input type="radio" name="team_required" value="no" /> No</label>
          </fieldset>
        </div>
      </div>

      <label>
        Minimum skill level
        <select name="min_skill_level">
          <option value="">No minimum</option>
          <option value="C">C</option>
          <option value="B">B</option>
          <option value="BB">BB</option>
          <option value="A">A</option>
          <option value="AA">AA</option>
        </select>
      </label>

      <label>
        Meetup link or contact email
        <input type="text" name="external_link" />
      </label>

      <label>
        Payment types
        <input type="text" name="payment_types" />
      </label>

      <label>
        Photo URL
        <input type="text" name="photo_url" />
      </label>

      <label>
        Notes
        <textarea name="notes" maxlength="250"></textarea>
      </label>

      <p class="edit-message" id="edit-message" role="status"></p>

      <div class="edit-actions">
        <button type="button" id="edit-cancel">Cancel</button>
        <button type="submit">Save changes</button>
      </div>
    </form>
  </dialog>
</BaseLayout>

<style>
  .admin-page {
    width: 100%;
    max-width: 48rem;
    margin: 0 auto;
    padding: 2rem 1rem 4rem;

    section + section {
      margin-top: 2rem;
    }

    h2 {
      font-size: 1.1rem;
    }

    .section-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      margin-bottom: 0.5rem;
    }

    .admin-tabs {
      display: flex;
      gap: 0.5rem;
      margin-bottom: 1.5rem;
    }

    .admin-tab {
      padding: 0.5rem 1rem;
      font-size: 0.875rem;
      font-weight: 600;
      color: #666;
      background: none;
      border: none;
      border-bottom: 2px solid transparent;
      cursor: pointer;
    }

    .admin-tab[aria-selected="true"] {
      color: var(--color-accent);
      border-bottom-color: var(--color-accent);
    }

    .sort-label {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 0.8rem;
      color: #666;

      select {
        padding: 0.25rem 0.4rem;
        font-size: 0.8rem;
        border: 1px solid #ccc;
        border-radius: 0.25rem;
      }
    }

    .listing-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      padding: 0.75rem;
      margin-bottom: 0.5rem;
      background: white;
      border: 1px solid #e5e5e5;
      border-radius: 0.375rem;
      font-size: 0.875rem;

      .listing-info {
        flex: 1;
      }

      .listing-info-group {
        flex: 1;
        min-width: 0;
      }

      .listing-submitted-address {
        margin-top: 0.2rem;
        font-size: 0.8rem;
        color: #666;
      }

      .vote-counts {
        margin-left: 0.5rem;
        font-size: 0.8rem;
        color: #666;
      }

      .listing-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;

        button {
          padding: 0.35rem 0.75rem;
          font-size: 0.8rem;
          border: 1px solid #ccc;
          border-radius: 0.25rem;
          cursor: pointer;
          background: white;
        }

        button.approve {
          color: white;
          background: #2e9e44;
          border-color: #2e9e44;
        }

        button.reject {
          color: white;
          background: #c0392b;
          border-color: #c0392b;
        }
      }
    }

    .empty-state {
      font-size: 0.875rem;
      color: #666;
    }
  }
</style>

<style>
  #edit-dialog {
    width: min(36rem, calc(100vw - 2rem));
    max-height: calc(100vh - 4rem);
    padding: 1.5rem;
    border: none;
    border-radius: 0.5rem;
    box-shadow: 0 0.5rem 1.5rem rgb(0 0 0 / 25%);

    &::backdrop {
      background: rgb(0 0 0 / 40%);
    }

    h2 {
      margin: 0 0 1rem;
      font-size: 1.1rem;
    }
  }

  #edit-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    font-size: 0.875rem;

    label {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
      flex: 1;
    }

    .field-row {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
    }

    .kind-conditional[hidden] {
      display: none;
    }

    .field-hint {
      font-size: 0.75rem;
      font-weight: 400;
      color: #666;
    }

    .decode-maps-row {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      margin-top: -0.5rem;

      button {
        padding: 0.3rem 0.6rem;
        font-size: 0.75rem;
        background: #f0f0f0;
        border: 1px solid #ccc;
        border-radius: 0.25rem;
        cursor: pointer;
      }

      span {
        font-size: 0.75rem;
        color: #666;
      }
    }

    fieldset {
      display: flex;
      flex-direction: column;
      gap: 0.3rem;
      padding: 0;
      border: none;

      legend {
        margin-bottom: 0.15rem;
        font-weight: 600;
      }

      label {
        flex-direction: row;
        align-items: center;
        gap: 0.4rem;
        font-weight: 400;
      }
    }

    input[type="text"],
    input[type="number"],
    select,
    textarea {
      padding: 0.4rem;
      font-family: inherit;
      font-size: 0.875rem;
      border: 1px solid #ccc;
      border-radius: 0.25rem;
    }

    .day-time-edit {
      .day-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 0.35rem;
      }

      .day-chip {
        position: relative;
        flex: initial;

        input {
          position: absolute;
          opacity: 0;
          width: 100%;
          height: 100%;
          margin: 0;
          cursor: pointer;
        }

        span {
          display: block;
          padding: 0.3rem 0.6rem;
          font-size: 0.8rem;
          font-weight: 600;
          background: white;
          border: 1px solid #ccc;
          border-radius: 999px;
          user-select: none;
        }

        input:checked + span {
          color: white;
          background: var(--color-accent);
          border-color: var(--color-accent);
        }
      }

      .day-time-rows {
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
        margin-top: 0.5rem;
      }

      .day-time-row:not([hidden]) {
        display: flex;
        align-items: center;
        gap: 0.4rem;

        .day-time-row-label {
          width: 2.5rem;
          font-weight: 600;
        }

        .time-trigger {
          padding: 0.25rem 0.5rem;
          font-size: 0.85rem;
          background: white;
          border: 1px solid #ccc;
          border-radius: 0.3rem;
          cursor: pointer;
        }
      }
    }

    .edit-message {
      margin: 0;
      min-height: 1rem;
      color: #c0392b;
    }

    .edit-actions {
      display: flex;
      justify-content: flex-end;
      gap: 0.5rem;

      button {
        padding: 0.45rem 1rem;
        font-size: 0.875rem;
        border: 1px solid #ccc;
        border-radius: 0.25rem;
        cursor: pointer;
        background: white;
      }

      button[type="submit"] {
        color: white;
        background: var(--color-accent);
        border-color: var(--color-accent);
      }
    }
  }
</style>

<script>
  import { supabase } from '../../lib/supabase/client';
  import { formatListingTypeLabel } from '../../lib/listings/typeLabel';
  import { formatDateRange } from '../../lib/listings/formatDateRange';
  import type { DayTime, Listing as FullListing } from '../../types/listing';

  function tournamentDateLine(listing: FullListing): string {
    if (!listing.start_date || !listing.end_date) return '';
    const emoji = listing.listing_kind === 'league' ? '🏟️' : '🏆';
    return `<div class="listing-submitted-address">${emoji} ${formatDateRange(listing.start_date, listing.end_date)}</div>`;
  }

  function formatTime12h(value: string): string {
    const [hourStr, minute] = value.split(':');
    const hour = Number(hourStr);
    const period = hour >= 12 ? 'PM' : 'AM';
    const hour12 = hour % 12 === 0 ? 12 : hour % 12;
    return `${hour12}:${minute} ${period}`;
  }

  function setTimeField(name: string, value: string) {
    const hiddenInput = editForm?.elements.namedItem(name) as HTMLInputElement | null;
    const button = editForm?.querySelector<HTMLButtonElement>(`[data-time-trigger="${name}"]`);
    if (!hiddenInput || !button) return;
    hiddenInput.value = value;
    button.textContent = value ? formatTime12h(value) : name.startsWith('start_') ? 'Set start' : 'Set end';
  }

  const statusMessage = document.querySelector<HTMLParagraphElement>('#status-message');
  const content = document.querySelector<HTMLElement>('#admin-content');
  const pendingList = document.querySelector<HTMLDivElement>('#pending-list');
  const reportsList = document.querySelector<HTMLDivElement>('#reports-list');
  const allListingsList = document.querySelector<HTMLDivElement>('#all-listings-list');

  interface Report {
    id: string;
    listing_id: string;
    note: string;
    created_at: string;
    listings: { name: string | null; type: string; status: string; listing_kind: string } | null;
  }

  // Looked up by id when "Edit" is clicked — both dashboard sections
  // already fetch full rows (select('*')), so no extra request needed.
  const listingsById = new Map<string, FullListing>();

  // Cached so the sort dropdown and the kind tabs (ROB-124) can
  // re-render client-side instead of re-fetching — the full lists are
  // already in memory either way.
  let allListingsCache: FullListing[] = [];
  let pendingCache: FullListing[] = [];
  let reportsCache: Report[] = [];
  let activeKind = 'recurring';
  const allListingsSort = document.querySelector<HTMLSelectElement>('#all-listings-sort');

  function sortListings(listings: FullListing[], sortBy: string): FullListing[] {
    const sorted = [...listings];
    switch (sortBy) {
      case 'alpha':
        return sorted.sort((a, b) =>
          (a.name ?? `${a.type} listing`).localeCompare(b.name ?? `${b.type} listing`),
        );
      case 'date-asc':
        return sorted.sort((a, b) => a.created_at.localeCompare(b.created_at));
      case 'upvoted':
        // Never-upvoted listings sort to the end rather than the front,
        // since "no last_upvote_at" isn't the same as "upvoted long ago".
        return sorted.sort((a, b) => {
          if (!a.last_upvote_at && !b.last_upvote_at) return 0;
          if (!a.last_upvote_at) return 1;
          if (!b.last_upvote_at) return -1;
          return b.last_upvote_at.localeCompare(a.last_upvote_at);
        });
      case 'date-desc':
      default:
        return sorted.sort((a, b) => b.created_at.localeCompare(a.created_at));
    }
  }

  async function getAccessToken(): Promise<string | null> {
    const { data } = await supabase.auth.getSession();
    return data.session?.access_token ?? null;
  }

  async function apiFetch(path: string, options: RequestInit = {}) {
    const token = await getAccessToken();
    const response = await fetch(path, {
      ...options,
      headers: {
        ...options.headers,
        Authorization: `Bearer ${token}`,
        ...(options.body ? { 'content-type': 'application/json' } : {}),
      },
    });
    return response;
  }

  // Action button handlers previously discarded the response entirely —
  // a failed approve/reject/override (e.g. geocoding failure on
  // approve) looked like clicking the button did nothing, with no
  // indication why (ROB-108). Surfaces the API's error message instead.
  async function reportIfFailed(response: Response, fallback: string): Promise<boolean> {
    if (response.ok) return false;
    const data = await response.json().catch(() => ({}));
    if (statusMessage) statusMessage.textContent = data.error ?? fallback;
    return true;
  }

  function renderPending(listings: FullListing[]) {
    if (!pendingList) return;
    if (listings.length === 0) {
      pendingList.innerHTML = '<p class="empty-state">Nothing pending review.</p>';
      return;
    }

    pendingList.innerHTML = listings
      .map(
        (listing) => `
        <div class="listing-row" data-id="${listing.id}">
          <div class="listing-info-group">
            <div class="listing-info">${listing.name ?? `${formatListingTypeLabel(listing.type)} listing`} — ${formatListingTypeLabel(listing.type)}, ${listing.cost ?? 'cost unknown'}</div>
            ${tournamentDateLine(listing)}
            ${listing.submitted_address ? `<div class="listing-submitted-address">📍 As entered: ${listing.submitted_address}</div>` : ''}
          </div>
          <div class="listing-actions">
            <button data-action="edit" data-id="${listing.id}">Edit</button>
            <button class="approve" data-action="approve" data-id="${listing.id}">Approve</button>
            <button class="reject" data-action="reject" data-id="${listing.id}">Reject</button>
          </div>
        </div>`,
      )
      .join('');
  }

  function renderReports(reports: Report[]) {
    if (!reportsList) return;
    if (reports.length === 0) {
      reportsList.innerHTML = '<p class="empty-state">No reports.</p>';
      return;
    }

    reportsList.innerHTML = reports
      .map(
        (report) => `
        <div class="listing-row" data-id="${report.id}">
          <div class="listing-info">
            <strong>${report.listings?.name ?? 'Unknown listing'}</strong> (${report.listings?.status ?? 'unknown'})<br>
            ${report.note}
          </div>
          <div class="listing-actions">
            <button data-action="edit" data-id="${report.listing_id}">View/Edit listing</button>
            <button data-action="archive-report" data-id="${report.id}">Archive</button>
          </div>
        </div>`,
      )
      .join('');
  }

  function renderAllListings(listings: FullListing[]) {
    if (!allListingsList) return;
    if (listings.length === 0) {
      allListingsList.innerHTML = '<p class="empty-state">No listings yet.</p>';
      return;
    }

    allListingsList.innerHTML = listings
      .map(
        (listing) => `
        <div class="listing-row" data-id="${listing.id}">
          <div class="listing-info">
            ${listing.name ?? `${formatListingTypeLabel(listing.type)} listing`} — ${listing.status}${listing.decayed ? ' · decayed' : ''}
            <span class="vote-counts">👍 ${listing.upvotes ?? 0} · 👎 ${listing.downvotes ?? 0}</span>
            ${tournamentDateLine(listing)}
          </div>
          <div class="listing-actions">
            <button data-action="edit" data-id="${listing.id}">Edit</button>
            <button data-action="toggle-decayed" data-id="${listing.id}" data-decayed="${listing.decayed}">
              ${listing.decayed ? 'Clear decayed' : 'Mark decayed'}
            </button>
            ${
              listing.status === 'rejected'
                ? `<button data-action="reactivate" data-id="${listing.id}">Reactivate</button>`
                : `<button class="reject" data-action="deactivate" data-id="${listing.id}">Mark inactive</button>`
            }
          </div>
        </div>`,
      )
      .join('');
  }

  async function loadDashboard() {
    const [pendingRes, reportsRes, allRes] = await Promise.all([
      apiFetch('/api/admin/listings?status=pending'),
      apiFetch('/api/admin/reports'),
      apiFetch('/api/admin/listings'),
    ]);

    if (pendingRes.status === 401 || pendingRes.status === 403) {
      if (statusMessage) statusMessage.textContent = 'Not authorized.';
      return;
    }

    const { listings: pending } = await pendingRes.json();
    const { reports } = await reportsRes.json();
    const { listings: all } = await allRes.json();

    if (content) content.hidden = false;
    if (statusMessage) statusMessage.textContent = '';

    listingsById.clear();
    for (const listing of [...(pending ?? []), ...(all ?? [])]) {
      listingsById.set(listing.id, listing);
    }

    pendingCache = pending ?? [];
    reportsCache = reports ?? [];
    allListingsCache = all ?? [];

    renderDashboard();
  }

  // Re-renders all three sections from the cached fetches, filtered down
  // to whichever Kind tab is active (ROB-124) — listings of different
  // kinds have different relevant fields (a tournament's dates vs. a
  // meetup's weekly days), so mixing them in one list got noisy as
  // tournament/league listings were added.
  function renderDashboard() {
    renderPending(pendingCache.filter((listing) => listing.listing_kind === activeKind));
    renderReports(reportsCache.filter((report) => report.listings?.listing_kind === activeKind));
    renderAllListings(
      sortListings(
        allListingsCache.filter((listing) => listing.listing_kind === activeKind),
        allListingsSort?.value ?? 'date-desc',
      ),
    );
  }

  for (const tabBtn of document.querySelectorAll<HTMLButtonElement>('.admin-tab')) {
    tabBtn.addEventListener('click', () => {
      activeKind = tabBtn.dataset.kind ?? 'recurring';
      for (const btn of document.querySelectorAll<HTMLButtonElement>('.admin-tab')) {
        btn.setAttribute('aria-selected', String(btn === tabBtn));
      }
      renderDashboard();
    });
  }

  allListingsSort?.addEventListener('change', renderDashboard);

  // --- Edit dialog ---

  const editDialog = document.querySelector<HTMLDialogElement>('#edit-dialog');
  const editForm = document.querySelector<HTMLFormElement>('#edit-form');
  const editMessage = document.querySelector<HTMLParagraphElement>('#edit-message');
  let editingId: string | null = null;

  function setRadioValue(name: string, value: string) {
    const input = editForm?.querySelector<HTMLInputElement>(`input[name="${name}"][value="${value}"]`);
    if (input) input.checked = true;
  }

  // Field groups that don't apply to every kind (e.g. a tournament's
  // fixed start/end date vs. a recurring meetup's weekly schedule) carry
  // a data-kind-show list of the kinds they're relevant for — kept data-
  // driven rather than a kind-by-kind if/else so adding a new kind-
  // specific group later is just one more attribute, not new branches.
  function applyKindVisibility(kind: string) {
    for (const el of editForm?.querySelectorAll<HTMLElement>('[data-kind-show]') ?? []) {
      const allowedKinds = el.dataset.kindShow?.split(',') ?? [];
      el.hidden = !allowedKinds.includes(kind);
    }
  }

  for (const radio of editForm?.querySelectorAll<HTMLInputElement>('input[name="listing_kind"]') ?? []) {
    radio.addEventListener('change', () => {
      if (radio.checked) applyKindVisibility(radio.value);
    });
  }

  function openEditDialog(listing: FullListing) {
    if (!editForm || !editDialog) return;
    editForm.reset();
    if (editMessage) editMessage.textContent = '';
    editingId = listing.id;

    (editForm.elements.namedItem('name') as HTMLInputElement).value = listing.name ?? '';
    setRadioValue('type', listing.type);
    setRadioValue('cost', listing.cost ?? '');
    setRadioValue('visibility', listing.visibility);
    setRadioValue('listing_kind', listing.listing_kind);
    applyKindVisibility(listing.listing_kind);
    (editForm.elements.namedItem('start_date') as HTMLInputElement).value = listing.start_date ?? '';
    (editForm.elements.namedItem('end_date') as HTMLInputElement).value = listing.end_date ?? '';
    (editForm.elements.namedItem('lat') as HTMLInputElement).value = String(listing.lat);
    (editForm.elements.namedItem('lng') as HTMLInputElement).value = String(listing.lng);
    (editForm.elements.namedItem('submitted_address') as HTMLInputElement).value = listing.submitted_address ?? '';
    (editForm.elements.namedItem('address') as HTMLInputElement).value = listing.address ?? '';
    (editForm.elements.namedItem('google_maps_url') as HTMLInputElement).value = listing.google_maps_url ?? '';
    (editForm.elements.namedItem('city') as HTMLInputElement).value = listing.city ?? '';
    (editForm.elements.namedItem('neighborhood') as HTMLInputElement).value = listing.neighborhood ?? '';
    setRadioValue('signup_required', listing.signup_required === null ? '' : listing.signup_required ? 'yes' : 'no');
    setRadioValue('equipment_supplied', listing.equipment_supplied === null ? '' : listing.equipment_supplied ? 'yes' : 'no');
    setRadioValue('team_required', listing.team_required === null ? '' : listing.team_required ? 'yes' : 'no');
    (editForm.elements.namedItem('min_skill_level') as HTMLSelectElement).value = listing.min_skill_level ?? '';
    (editForm.elements.namedItem('external_link') as HTMLInputElement).value = listing.external_link ?? '';
    (editForm.elements.namedItem('payment_types') as HTMLInputElement).value = listing.payment_types ?? '';
    (editForm.elements.namedItem('photo_url') as HTMLInputElement).value = listing.photo_url ?? '';
    (editForm.elements.namedItem('notes') as HTMLTextAreaElement).value = listing.notes ?? '';

    for (const dayTime of listing.days_times) {
      const checkbox = editForm.querySelector<HTMLInputElement>(`input[data-day="${dayTime.day}"]`);
      const row = editForm.querySelector<HTMLDivElement>(`[data-day-row="${dayTime.day}"]`);
      if (checkbox) checkbox.checked = true;
      if (row) row.hidden = false;
      setTimeField(`start_${dayTime.day}`, dayTime.start_time ?? '');
      setTimeField(`end_${dayTime.day}`, dayTime.end_time ?? '');
    }

    editDialog.showModal();
  }

  for (const checkbox of editForm?.querySelectorAll<HTMLInputElement>('.day-chip input[type="checkbox"]') ?? []) {
    const row = editForm?.querySelector<HTMLDivElement>(`[data-day-row="${checkbox.dataset.day}"]`);
    checkbox.addEventListener('change', () => {
      if (!row) return;
      row.hidden = !checkbox.checked;
      if (!checkbox.checked) {
        for (const timeButton of row.querySelectorAll<HTMLButtonElement>('.time-trigger')) {
          const fieldName = timeButton.dataset.timeTrigger;
          if (fieldName) setTimeField(fieldName, '');
        }
      }
    });
  }

  for (const button of editForm?.querySelectorAll<HTMLButtonElement>('.time-trigger') ?? []) {
    button.addEventListener('click', () => {
      const fieldName = button.dataset.timeTrigger;
      if (!fieldName) return;
      const hiddenInput = editForm?.elements.namedItem(fieldName) as HTMLInputElement | null;
      // Looked up lazily — see DayTimePicker.astro for why this can't
      // be cached at module-eval time.
      (window as unknown as { openClockPicker: (value: string, callback: (value: string) => void) => void }).openClockPicker(
        hiddenInput?.value ?? '',
        (newValue) => setTimeField(fieldName, newValue),
      );
    });
  }

  document.querySelector('#edit-cancel')?.addEventListener('click', () => editDialog?.close());

  document.querySelector('#decode-maps-btn')?.addEventListener('click', async () => {
    const decodeMessage = document.querySelector<HTMLSpanElement>('#decode-maps-message');
    const url = (editForm?.elements.namedItem('google_maps_url') as HTMLInputElement | null)?.value.trim();
    if (!url) {
      if (decodeMessage) decodeMessage.textContent = 'Add a Google Maps link first.';
      return;
    }

    if (decodeMessage) decodeMessage.textContent = 'Decoding…';
    const response = await apiFetch('/api/admin/listings/decode-maps-link', {
      method: 'POST',
      body: JSON.stringify({ url }),
    });
    const data = await response.json().catch(() => ({}));

    if (!response.ok) {
      if (decodeMessage) decodeMessage.textContent = data.error ?? 'Decode failed.';
      return;
    }

    (editForm?.elements.namedItem('lat') as HTMLInputElement).value = String(data.lat);
    (editForm?.elements.namedItem('lng') as HTMLInputElement).value = String(data.lng);
    // address/city/neighborhood come back when the Maps link embeds a
    // real address, or as a fallback when it doesn't (re-geocoded using
    // the link's precise coordinates) — only overwrite fields the
    // response actually included.
    if (data.address) (editForm?.elements.namedItem('address') as HTMLInputElement).value = data.address;
    if (data.city) (editForm?.elements.namedItem('city') as HTMLInputElement).value = data.city;
    if (data.neighborhood) (editForm?.elements.namedItem('neighborhood') as HTMLInputElement).value = data.neighborhood;
    if (decodeMessage) {
      decodeMessage.textContent = data.address ? `Set to ${data.address}` : `Set to ${data.lat}, ${data.lng}`;
    }
  });

  editForm?.addEventListener('submit', async (event) => {
    event.preventDefault();
    if (!editingId) return;

    const formData = new FormData(editForm);
    const cost = formData.get('cost');
    const signupRequired = formData.get('signup_required');
    const equipmentSupplied = formData.get('equipment_supplied');
    const teamRequired = formData.get('team_required');
    const days = formData.getAll('days') as string[];
    const listingKind = formData.get('listing_kind') as string;
    const isTournament = listingKind === 'tournament';
    const isDatedListing = isTournament || listingKind === 'league';

    const daysTimes: DayTime[] = days.map((day) => ({
      day: day as DayTime['day'],
      start_time: (formData.get(`start_${day}`) as string) || null,
      end_time: (formData.get(`end_${day}`) as string) || null,
    }));

    const payload = {
      name: (formData.get('name') as string) || null,
      type: formData.get('type'),
      cost: cost === '' ? null : cost,
      visibility: formData.get('visibility'),
      listing_kind: listingKind,
      // Kind-conditional fields are nulled/cleared here rather than
      // trusted from the form directly — switching the Kind radio hides
      // a group without clearing its inputs, so a stale value left over
      // from before the switch could otherwise still get saved.
      start_date: isDatedListing ? (formData.get('start_date') as string) || null : null,
      end_date: isDatedListing ? (formData.get('end_date') as string) || null : null,
      lat: Number(formData.get('lat')),
      lng: Number(formData.get('lng')),
      submitted_address: (formData.get('submitted_address') as string) || null,
      address: (formData.get('address') as string) || null,
      google_maps_url: (formData.get('google_maps_url') as string) || null,
      city: (formData.get('city') as string) || null,
      neighborhood: (formData.get('neighborhood') as string) || null,
      days_times: isTournament ? [] : daysTimes,
      signup_required: signupRequired === '' ? null : signupRequired === 'yes',
      equipment_supplied: listingKind === 'recurring' ? (equipmentSupplied === '' ? null : equipmentSupplied === 'yes') : null,
      team_required: listingKind === 'recurring' ? (teamRequired === '' ? null : teamRequired === 'yes') : null,
      min_skill_level: (formData.get('min_skill_level') as string) || null,
      external_link: (formData.get('external_link') as string) || null,
      payment_types: (formData.get('payment_types') as string) || null,
      photo_url: (formData.get('photo_url') as string) || null,
      notes: (formData.get('notes') as string) || null,
    };

    const response = await apiFetch(`/api/admin/listings/${editingId}/edit`, {
      method: 'POST',
      body: JSON.stringify(payload),
    });

    if (!response.ok) {
      const { error } = await response.json().catch(() => ({ error: 'Save failed' }));
      if (editMessage) editMessage.textContent = error ?? 'Save failed';
      return;
    }

    editDialog?.close();
    loadDashboard();
  });

  function handleEditClick(id: string | undefined) {
    if (!id) return;
    const listing = listingsById.get(id);
    if (listing) openEditDialog(listing);
  }

  pendingList?.addEventListener('click', async (event) => {
    const button = (event.target as HTMLElement).closest<HTMLButtonElement>('button[data-action]');
    if (!button) return;

    const { action, id } = button.dataset;
    if (action === 'edit') {
      handleEditClick(id);
      return;
    }
    if (statusMessage) statusMessage.textContent = '';
    const response = await apiFetch(`/api/admin/listings/${id}/${action}`, { method: 'POST' });
    // loadDashboard() unconditionally clears #status-message, so calling
    // it after a failure would wipe the error out almost immediately
    // (ROB-112) — only refresh the list when the action actually
    // succeeded; nothing changed server-side on failure anyway.
    const failed = await reportIfFailed(response, `Failed to ${action} listing.`);
    if (!failed) loadDashboard();
  });

  reportsList?.addEventListener('click', async (event) => {
    const button = (event.target as HTMLElement).closest<HTMLButtonElement>('button[data-action]');
    if (!button) return;

    const { action, id } = button.dataset;
    if (action === 'edit') {
      handleEditClick(id);
      return;
    }

    if (statusMessage) statusMessage.textContent = '';
    const response = await apiFetch(`/api/admin/reports/${id}/archive`, { method: 'POST' });
    const failed = await reportIfFailed(response, 'Failed to archive report.');
    if (!failed) loadDashboard();
  });

  allListingsList?.addEventListener('click', async (event) => {
    const button = (event.target as HTMLElement).closest<HTMLButtonElement>('button[data-action]');
    if (!button) return;

    const { action, id, decayed } = button.dataset;

    if (action === 'edit') {
      handleEditClick(id);
      return;
    }

    if (statusMessage) statusMessage.textContent = '';
    let response: Response | undefined;
    if (action === 'toggle-decayed') {
      response = await apiFetch(`/api/admin/listings/${id}/override`, {
        method: 'POST',
        body: JSON.stringify({ decayed: decayed !== 'true' }),
      });
    } else if (action === 'deactivate') {
      response = await apiFetch(`/api/admin/listings/${id}/override`, {
        method: 'POST',
        body: JSON.stringify({ status: 'rejected' }),
      });
    } else if (action === 'reactivate') {
      response = await apiFetch(`/api/admin/listings/${id}/override`, {
        method: 'POST',
        body: JSON.stringify({ status: 'approved' }),
      });
    }

    const failed = response ? await reportIfFailed(response, `Failed to ${action} listing.`) : false;
    if (!failed) loadDashboard();
  });

  supabase.auth.onAuthStateChange((_event, session) => {
    if (!session) {
      if (statusMessage) statusMessage.textContent = 'You need to sign in as an admin to view this page.';
      if (content) content.hidden = true;
      return;
    }
    loadDashboard();
  });
</script>
