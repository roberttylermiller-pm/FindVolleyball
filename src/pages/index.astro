---
import BaseLayout from '../layouts/BaseLayout.astro';
import Map from '../components/Map.astro';
import Filters from '../components/Filters.astro';
import LocationSearch from '../components/LocationSearch.astro';
import WelcomeModal from '../components/WelcomeModal.astro';
import Toast from '../components/Toast.astro';
---

<BaseLayout hideFooter>
  <main>
    <WelcomeModal />
    <Toast />
    <div class="map-controls">
      <div class="map-controls-row">
        <LocationSearch />
        <!-- Only shown on narrow screens (ROB-120) — on wider ones
             .filters-panel is always visible and this stays hidden. -->
        <button
          id="filters-toggle"
          type="button"
          class="filters-toggle"
          aria-expanded="false"
          aria-controls="filters-panel"
        >
          Filters ▾
        </button>
      </div>
      <div id="filters-panel" class="filters-panel">
        <Filters />
      </div>
    </div>
    <Map />
  </main>
</BaseLayout>

<style>
  main {
    position: relative;
    flex: 1;
    min-height: 0;
  }

  .map-controls {
    position: fixed;
    top: calc(var(--header-height) + 1rem);
    left: 1rem;
    right: 1rem;
    z-index: 1000;
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .map-controls-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  /* Hidden on wider screens — filters-panel is always visible there,
     same as before this ticket. Only appears (and only matters) below
     the breakpoint where the filter chips would otherwise permanently
     eat into the map's vertical space (ROB-120). */
  .filters-toggle {
    display: none;
  }

  @media (max-width: 480px) {
    /* The search box alone (it has its own min-width) can already use
       most of the available row width on a narrow phone, leaving no
       room for this button beside it — it was overflowing off the
       right edge of the screen instead of wrapping. Letting the row
       wrap, with this pushed to the end of whichever line it lands on,
       drops it to its own line under the search box instead. */
    .map-controls-row {
      flex-wrap: wrap;
    }

    .filters-toggle {
      display: inline-flex;
      align-items: center;
      margin-left: auto;
      padding: 0.4rem 0.75rem;
      font-size: 0.8rem;
      font-weight: 600;
      color: white;
      background: #1a1a1a;
      border: none;
      border-radius: 0.4rem;
      cursor: pointer;
      white-space: nowrap;
    }

    .filters-panel {
      flex-basis: 100%;
    }

    .filters-panel:not(.expanded) {
      display: none;
    }
  }
</style>

<script>
  const filtersToggle = document.querySelector<HTMLButtonElement>('#filters-toggle');
  const filtersPanel = document.querySelector<HTMLDivElement>('#filters-panel');

  filtersToggle?.addEventListener('click', () => {
    const expanded = filtersPanel?.classList.toggle('expanded') ?? false;
    filtersToggle.setAttribute('aria-expanded', String(expanded));
    filtersToggle.textContent = expanded ? 'Filters ▴' : 'Filters ▾';
  });
</script>
