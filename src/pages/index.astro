---
import BaseLayout from '../layouts/BaseLayout.astro';
import Map from '../components/Map.astro';
import Filters from '../components/Filters.astro';
import ListView from '../components/ListView.astro';
import LocationSearch from '../components/LocationSearch.astro';
import IntroStrip from '../components/IntroStrip.astro';
import Toast from '../components/Toast.astro';
---

<BaseLayout hideFooter>
  <main>
    <IntroStrip />
    <Toast />
    <div class="map-controls">
      <div class="map-controls-row">
        <LocationSearch />
        <div class="toggle-divider" aria-hidden="true"></div>
        <!-- Filters and List (ROB-158) are a single mutually-exclusive
             control cluster alongside search, all one bar — opening one
             collapses the other (see script below), same as volleymap's
             reference pattern. Both toggle at every screen width now;
             Filters is no longer permanently visible on wide screens. -->
        <button
          id="filters-toggle"
          type="button"
          class="filters-toggle"
          aria-expanded="false"
          aria-controls="filters-panel"
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <line x1="4" y1="6" x2="20" y2="6"></line>
            <circle cx="9" cy="6" r="2" fill="currentColor" stroke="none"></circle>
            <line x1="4" y1="12" x2="20" y2="12"></line>
            <circle cx="15" cy="12" r="2" fill="currentColor" stroke="none"></circle>
            <line x1="4" y1="18" x2="20" y2="18"></line>
            <circle cx="7" cy="18" r="2" fill="currentColor" stroke="none"></circle>
          </svg>
          <span class="toggle-label">Filters</span>
        </button>
        <button id="list-toggle" type="button" class="list-toggle" aria-expanded="false" aria-controls="list-panel">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <line x1="8" y1="6" x2="20" y2="6"></line>
            <line x1="8" y1="12" x2="20" y2="12"></line>
            <line x1="8" y1="18" x2="20" y2="18"></line>
            <circle cx="4" cy="6" r="1.2" fill="currentColor" stroke="none"></circle>
            <circle cx="4" cy="12" r="1.2" fill="currentColor" stroke="none"></circle>
            <circle cx="4" cy="18" r="1.2" fill="currentColor" stroke="none"></circle>
          </svg>
          <span class="toggle-label">List</span>
        </button>
      </div>
      <div id="filters-panel" class="filters-panel">
        <Filters />
      </div>
    </div>
    <div class="map-layout">
      <div class="map-area">
        <Map />
      </div>
      <ListView />
    </div>
  </main>
</BaseLayout>

<style>
  main {
    position: relative;
    display: flex;
    flex-direction: column;
    flex: 1;
    min-height: 0;
  }

  .map-layout {
    display: flex;
    flex: 1;
    min-height: 0;
  }

  .map-area {
    position: relative;
    flex: 1;
    min-width: 0;
    height: 100%;
  }

  .map-controls {
    position: fixed;
    top: calc(var(--header-height) + var(--intro-strip-height) + 1rem);
    left: 1rem;
    right: 1rem;
    z-index: 1000;
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.75rem;
    transition: right 0.2s ease;
  }

  /* Leaves room for the expanded list pane instead of the search/filter
     bar floating over the top of it (ROB-131) — only on wider screens,
     where the list pane is a side-by-side column rather than a
     full-width replacement for the map (see ListView.astro's own
     breakpoint). */
  @media (min-width: 768px) {
    main:has(#list-panel.expanded) .map-controls {
      right: calc(24rem + 1rem);
    }
  }

  /* Filters and List (ROB-158) sit inside the same white bar as search
     now, rather than as separate dark buttons beside a separate white
     box — one continuous control cluster matching the volleymap
     reference. Neutral by default; the orange accent (same one the
     Search button and expanded-chip states already use) signals which
     panel is open. */
  .filters-toggle,
  .list-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    flex-shrink: 0;
    padding: 0.45rem 0.7rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #444;
    background: #f0f0f0;
    border: none;
    border-radius: var(--radius-sharp);
    cursor: pointer;
    white-space: nowrap;
    transition: opacity var(--motion-base);

    svg {
      width: 0.95rem;
      height: 0.95rem;
      flex-shrink: 0;
    }
  }

  .filters-toggle:hover,
  .list-toggle:hover {
    opacity: 0.88;
  }

  .filters-toggle:active,
  .list-toggle:active {
    transform: scale(0.97);
    transition-duration: var(--motion-fast);
  }

  .filters-toggle[aria-expanded="true"],
  .list-toggle[aria-expanded="true"] {
    color: white;
    background: var(--color-accent);
  }

  /* The single unified bar (ROB-158) — search input/button, a divider,
     then Filters and List all inside one continuous white pill instead
     of search having its own box next to a separately-styled pair of
     dark buttons. */
  .map-controls-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem;
    background: white;
    border-radius: var(--radius-sharp);
    box-shadow: 0 1px 4px rgb(0 0 0 / 20%);
  }

  .toggle-divider {
    flex-shrink: 0;
    width: 1px;
    height: 1.5rem;
    background: #e0e0e0;
  }

  /* Collapsed by default at every width now (ROB-158) — previously only
     true below 480px; on wider screens this used to stay permanently
     visible instead of behaving like a toggle. */
  .filters-panel:not(.expanded) {
    display: none;
  }

  @media (max-width: 480px) {
    /* No wrap — the search box (see LocationSearch.astro) is the
       element that gives up width here, shrinking down to a usable
       floor instead of this row wrapping the Filters toggle onto its
       own line. Width:100% so it actually has .map-controls' full
       available width to negotiate that shrink against, rather than
       just sizing to its own content (ROB-120 follow-up — a fixed
       pixel budget computed against a guessed viewport width kept not
       holding up on a real device). */
    .map-controls-row {
      flex-wrap: nowrap;
      width: 100%;
    }

    .filters-panel {
      flex-basis: 100%;
    }
  }
</style>

<script>
  import { LISTING_RESULTS_EVENT } from '../lib/map/events';

  const filtersToggle = document.querySelector<HTMLButtonElement>('#filters-toggle');
  const filtersPanel = document.querySelector<HTMLDivElement>('#filters-panel');
  const listToggle = document.querySelector<HTMLButtonElement>('#list-toggle');
  const listPanel = document.querySelector<HTMLElement>('#list-panel');
  // .toggle-label spans (ROB-158) — setting textContent on the whole
  // button would also wipe out its icon <svg>, so the swappable "List"/
  // "Map" text lives in its own child element instead.
  const listLabel = listToggle?.querySelector<HTMLSpanElement>('.toggle-label');

  function collapseList() {
    listPanel?.classList.remove('expanded');
    listToggle?.setAttribute('aria-expanded', 'false');
    if (listLabel) listLabel.textContent = 'List';
  }

  function collapseFilters() {
    filtersPanel?.classList.remove('expanded');
    filtersToggle?.setAttribute('aria-expanded', 'false');
  }

  // Filters and List (ROB-158) are mutually exclusive — one control
  // cluster with a single expanded panel at a time, matching volleymap's
  // reference pattern, rather than both able to stay open together.
  filtersToggle?.addEventListener('click', () => {
    const expanded = filtersPanel?.classList.toggle('expanded') ?? false;
    filtersToggle.setAttribute('aria-expanded', String(expanded));
    if (expanded) collapseList();
  });

  // List view toggle (ROB-131) — collapsed by default. Map.astro's own
  // ResizeObserver on #map already calls invalidateSize() whenever that
  // container's size changes, which the .map-area flex item shrinking
  // to make room for the expanded panel triggers on its own — no extra
  // handling needed here for that part.
  listToggle?.addEventListener('click', () => {
    const expanded = listPanel?.classList.toggle('expanded') ?? false;
    listToggle.setAttribute('aria-expanded', String(expanded));
    if (listLabel) listLabel.textContent = expanded ? 'Map' : 'List';
    if (expanded) collapseFilters();
  });

  // Restore list view state when returning via browser back from a listing
  // permalink. ListView.astro sets vb_restore_list before navigating away;
  // Map.astro uses the same flag to skip geolocation and use the saved
  // center/zoom instead.
  if (sessionStorage.getItem('vb_restore_list') === 'true') {
    sessionStorage.removeItem('vb_restore_list');
    listPanel?.classList.add('expanded');
    listToggle?.setAttribute('aria-expanded', 'true');
    if (listLabel) listLabel.textContent = 'Map';

    const savedScroll = sessionStorage.getItem('vb_list_scroll');
    if (savedScroll && listPanel) {
      // Wait for the first LISTING_RESULTS_EVENT (Map.astro finishes its
      // fetch and ListView.astro renders the cards) before restoring
      // scroll — the panel has no scrollable content before that point.
      window.addEventListener(
        LISTING_RESULTS_EVENT,
        () => {
          requestAnimationFrame(() => {
            listPanel.scrollTop = parseInt(savedScroll);
            sessionStorage.removeItem('vb_list_scroll');
          });
        },
        { once: true },
      );
    }
  }
</script>
