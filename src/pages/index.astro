---
import BaseLayout from '../layouts/BaseLayout.astro';
import Map from '../components/Map.astro';
import Filters from '../components/Filters.astro';
import LocationSearch from '../components/LocationSearch.astro';
import WelcomeModal from '../components/WelcomeModal.astro';
---

<BaseLayout hideFooter>
  <main>
    <WelcomeModal />
    <div class="map-controls">
      <LocationSearch />
      <Filters />
    </div>
    <Map />
  </main>
</BaseLayout>

<style>
  main {
    position: relative;
    flex: 1;
    min-height: 0;
  }

  .map-controls {
    position: fixed;
    top: calc(var(--header-height) + 1rem);
    left: 1rem;
    right: 1rem;
    z-index: 1000;
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.75rem;
  }
</style>
