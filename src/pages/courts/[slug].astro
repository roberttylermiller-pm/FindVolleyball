---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { supabase } from '../../lib/supabase/client';
import { buildCourtMetadata } from '../../lib/seo/courtMetadata';
import { formatDayTime } from '../../lib/listings/formatDayTime';
import { capitalize } from '../../lib/text';
import { formatVisibilityLabel } from '../../lib/listings/visibility';
import { isEmailAddress, buildExternalLinkHref, getExternalLinkLabel } from '../../lib/listings/externalLink';
import { buildMapsHref, formatAddressDisplay } from '../../lib/listings/address';
import type { Listing } from '../../types/listing';

// Rendered per-request rather than statically generated (ROB-72, ROB-73):
// a static build only knows about listings/edits that existed at the
// last deploy, so newly-seeded listings 404'd and admin edits to an
// existing listing (e.g. its address) never showed up here until the
// next redeploy. RLS already restricts anon reads to approved listings.
export const prerender = false;

const { slug } = Astro.params;

const { data, error } = await supabase
  .from('listings')
  .select('*')
  .eq('status', 'approved')
  .eq('slug', slug)
  .maybeSingle();

if (error || !data) {
  return new Response('Listing not found', { status: 404 });
}

const listing = data as Listing;

const { title, description } = buildCourtMetadata({
  type: listing.type,
  city: listing.city ?? '',
  neighborhood: listing.neighborhood,
});
---

<BaseLayout title={title} description={description}>
  <main class="court-page" data-listing-id={listing.id}>
    <h1>
      {listing.name ?? `${listing.type} volleyball in ${listing.neighborhood ?? listing.city}`}
      {listing.decayed && <span class="decayed-badge">Decayed — may no longer be active</span>}
    </h1>
    {
      formatAddressDisplay(listing) && (
        <a class="court-address" href={buildMapsHref(listing)} target="_blank" rel="noopener noreferrer">
          📍 {formatAddressDisplay(listing)}
        </a>
      )
    }
    {listing.photo_url && <img class="court-photo" src={listing.photo_url} alt={listing.name ?? `${listing.type} volleyball court`} />}
    <dl>
      <dt>Surface</dt>
      <dd>{capitalize(listing.type)}</dd>
      <dt>Cost</dt>
      <dd>{listing.cost ? capitalize(listing.cost) : 'Unknown'}</dd>
      <dt>Visibility</dt>
      <dd>{formatVisibilityLabel(listing.visibility)}</dd>
      {listing.days_times.length > 0 && (
        <>
          <dt>Days & Times</dt>
          <dd>{listing.days_times.map(formatDayTime).join(', ')}</dd>
        </>
      )}
      <dt>Sign-up required</dt>
      <dd>{listing.signup_required === null ? 'Not specified' : listing.signup_required ? 'Yes' : 'No'}</dd>
      {listing.min_skill_level && (
        <>
          <dt>Minimum skill level</dt>
          <dd>{listing.min_skill_level}</dd>
        </>
      )}
      {listing.payment_types && (
        <>
          <dt>Payment types</dt>
          <dd>{listing.payment_types}</dd>
        </>
      )}
      {listing.team_required !== null && (
        <>
          <dt>Team required</dt>
          <dd>{listing.team_required ? 'Yes' : 'No'}</dd>
        </>
      )}
      {listing.notes && (
        <>
          <dt>Notes</dt>
          <dd>{listing.notes}</dd>
        </>
      )}
    </dl>
    {listing.external_link && (
      <p>
        <a
          href={buildExternalLinkHref(listing.external_link)}
          target={isEmailAddress(listing.external_link) ? undefined : '_blank'}
          rel={isEmailAddress(listing.external_link) ? undefined : 'noopener noreferrer'}
        >
          {getExternalLinkLabel(listing.external_link)}{!isEmailAddress(listing.external_link) && ' ↗'}
        </a>
      </p>
    )}

    <section class="vote-section">
      <p>Still happening?</p>
      <div class="vote-buttons">
        <button type="button" id="vote-up" aria-label="Still active">👍</button>
        <button type="button" id="vote-down" aria-label="No longer active">👎</button>
      </div>
      <p id="vote-message" role="status"></p>
    </section>

    <section class="report-section">
      <button type="button" id="report-toggle">Report an issue with this listing</button>
      <form id="report-form" hidden>
        <label class="honeypot-field" aria-hidden="true">
          Website
          <input type="text" name="website" tabindex="-1" autocomplete="off" />
        </label>
        <label>
          What's wrong? (250 char max)
          <textarea name="note" maxlength="250" required></textarea>
        </label>
        <button type="submit">Submit report</button>
      </form>
      <p id="report-message" role="status"></p>
    </section>
  </main>
</BaseLayout>

<style>
  .court-page {
    width: 100%;
    max-width: 32rem;
    margin: 0 auto;
    padding: 2rem 1rem 4rem;
  }

  .court-address {
    display: inline-block;
    margin: 0.5rem 0;
    padding: 0.35rem 0.6rem;
    color: var(--color-accent);
    font-weight: 600;
    text-decoration: underline;
    background: rgb(255 122 0 / 8%);
    border-radius: 0.3rem;
  }

  dl {
    display: grid;
    grid-template-columns: auto 1fr;
    column-gap: 1.25rem;
    row-gap: 0.7rem;
    margin: 1.5rem 0;
    padding: 1rem 1.25rem;
    background: white;
    border: 1px solid #e5e5e5;
    border-radius: 0.5rem;

    dt {
      color: #888;
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.03em;
      align-self: start;
      padding-top: 0.15rem;
    }

    dd {
      margin: 0;
      font-size: 0.9rem;
    }
  }

  .court-photo {
    width: 100%;
    max-height: 16rem;
    object-fit: cover;
    border-radius: 0.5rem;
    margin: 0.75rem 0;
  }

  .decayed-badge {
    display: inline-block;
    margin-left: 0.5rem;
    padding: 0.15rem 0.5rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: #856404;
    background: #fff3cd;
    border-radius: 0.25rem;
    vertical-align: middle;
  }

  .vote-section,
  .report-section {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid #e5e5e5;
  }

  .vote-buttons {
    display: flex;
    gap: 0.75rem;

    button {
      padding: 0.5rem 1rem;
      font-size: 1.25rem;
      background: white;
      border: 1px solid #ccc;
      border-radius: 0.375rem;
      cursor: pointer;
    }

    button:disabled {
      cursor: not-allowed;
      opacity: 0.5;
    }
  }

  .honeypot-field {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    left: -9999px;
  }

  #report-toggle {
    padding: 0;
    font-size: 0.875rem;
    color: #666;
    background: none;
    border: none;
    text-decoration: underline;
    cursor: pointer;
  }

  #report-form:not([hidden]) {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    max-width: 24rem;
    margin-top: 0.75rem;

    textarea {
      padding: 0.5rem;
      font-family: inherit;
      font-size: 0.875rem;
      border: 1px solid #ccc;
      border-radius: 0.25rem;
    }

    button[type="submit"] {
      align-self: flex-start;
      padding: 0.4rem 1rem;
      font-size: 0.875rem;
      color: white;
      background: var(--color-accent);
      border: none;
      border-radius: 0.25rem;
      cursor: pointer;
    }
  }
</style>

<script>
  const main = document.querySelector<HTMLElement>('.court-page');
  const listingId = main?.dataset.listingId;

  const voteUp = document.querySelector<HTMLButtonElement>('#vote-up');
  const voteDown = document.querySelector<HTMLButtonElement>('#vote-down');
  const voteMessage = document.querySelector<HTMLParagraphElement>('#vote-message');

  async function castVote(voteType: 'up' | 'down') {
    if (!listingId) return;
    voteUp?.setAttribute('disabled', 'true');
    voteDown?.setAttribute('disabled', 'true');

    const response = await fetch('/api/votes', {
      method: 'POST',
      headers: { 'content-type': 'application/json' },
      body: JSON.stringify({ listing_id: listingId, vote_type: voteType }),
    });

    if (voteMessage) {
      voteMessage.textContent = response.ok ? 'Thanks for the update!' : 'Something went wrong — please try again.';
    }
  }

  voteUp?.addEventListener('click', () => castVote('up'));
  voteDown?.addEventListener('click', () => castVote('down'));

  const reportToggle = document.querySelector<HTMLButtonElement>('#report-toggle');
  const reportForm = document.querySelector<HTMLFormElement>('#report-form');
  const reportMessage = document.querySelector<HTMLParagraphElement>('#report-message');

  reportToggle?.addEventListener('click', () => {
    if (reportForm) reportForm.hidden = !reportForm.hidden;
  });

  reportForm?.addEventListener('submit', async (event) => {
    event.preventDefault();
    if (!listingId) return;

    const formData = new FormData(reportForm);
    const note = String(formData.get('note') ?? '').trim();
    const website = String(formData.get('website') ?? '');
    if (!note) return;

    const response = await fetch('/api/reports', {
      method: 'POST',
      headers: { 'content-type': 'application/json' },
      body: JSON.stringify({ listing_id: listingId, note, website }),
    });

    if (reportMessage) {
      reportMessage.textContent = response.ok
        ? "Thanks — we'll take a look."
        : 'Something went wrong — please try again.';
    }

    if (response.ok) {
      reportForm.reset();
      reportForm.hidden = true;
    }
  });
</script>
