---
import BaseLayout from '../layouts/BaseLayout.astro';
import LocationPicker from '../components/LocationPicker.astro';
import DayTimePicker from '../components/DayTimePicker.astro';
---

<BaseLayout title="Submit a listing | FindVolleyball">
  <main class="submit-page">
    <div class="submit-tabs" role="tablist">
      <button type="button" class="submit-tab" data-tab="recurring" role="tab" aria-selected="true">Recurring Meetups</button>
      <button type="button" class="submit-tab" data-tab="tournament" role="tab" aria-selected="false">Tournament</button>
      <button type="button" class="submit-tab" data-tab="league" role="tab" aria-selected="false">League</button>
    </div>

    <h1 id="submit-heading">Add a recurring meetup</h1>
    <p id="auth-notice" hidden>You need to <a href="/login">sign in</a> to submit a listing.</p>

    <form id="submit-form" hidden>
      <input type="hidden" name="listing_kind" id="listing-kind-input" value="recurring" />

      <label class="honeypot-field" aria-hidden="true">
        Website
        <input type="text" name="website" tabindex="-1" autocomplete="off" />
      </label>

      <fieldset>
        <legend>Type *</legend>
        <label><input type="radio" name="type" value="indoor" required /> Indoor</label>
        <label><input type="radio" name="type" value="grass" /> Grass</label>
        <label><input type="radio" name="type" value="beach" /> Sand</label>
      </fieldset>

      <div class="tournament-only" hidden>
        <div class="field-row">
          <label>
            Start date *
            <input type="date" name="start_date" />
          </label>
          <label>
            End date *
            <input type="date" name="end_date" />
          </label>
        </div>
      </div>

      <LocationPicker />

      <div class="days-time-section">
        <DayTimePicker />
      </div>

      <label>
        Event link or contact email
        <input type="text" name="external_link" placeholder="https://meetup.com/... or your email" />
        <span class="field-hint">A signup/event page link, or an email if you don't have one.</span>
      </label>

      <details class="optional-fields">
        <summary>More details (optional)</summary>

        <fieldset>
          <legend>Cost</legend>
          <label><input type="radio" name="cost" value="" checked /> Not specified</label>
          <label><input type="radio" name="cost" value="free" /> Free</label>
          <label><input type="radio" name="cost" value="paid" /> Paid</label>
        </fieldset>

        <label id="payment-types-field" hidden>
          Cost amount / payment method
          <input type="text" name="payment_types" maxlength="100" placeholder="e.g. &quot;$10 cash only&quot; or &quot;$5/session via Venmo&quot;" />
        </label>

        <label>
          Google Maps link
          <input type="text" name="google_maps_url" placeholder="https://www.google.com/maps/place/..." />
          <span class="field-hint">If the address search above doesn't find the exact spot, paste the venue's Google Maps link here instead.</span>
        </label>

        <fieldset>
          <legend>Sign-ups required in advance?</legend>
          <label><input type="radio" name="signup_required" value="" checked /> Not specified</label>
          <label><input type="radio" name="signup_required" value="yes" /> Yes</label>
          <label><input type="radio" name="signup_required" value="no" /> No</label>
        </fieldset>

        <label>
          Name
          <input type="text" name="name" />
        </label>

        <div class="league-only" hidden>
          <div class="field-row">
            <label>
              Start month
              <input type="month" name="start_month" />
            </label>
            <label>
              End month
              <input type="month" name="end_month" />
            </label>
          </div>
          <p class="field-hint">
            Leave blank if you'd rather just note there's an ongoing league and point people to your site for exact
            dates.
          </p>
        </div>

        <label>
          Minimum skill level
          <select name="min_skill_level">
            <option value="">No minimum</option>
            <option value="C">C</option>
            <option value="B">B</option>
            <option value="BB">BB</option>
            <option value="A">A</option>
            <option value="AA">AA</option>
          </select>
        </label>

        <div class="recurring-only">
          <fieldset>
            <legend>Equipment supplied?</legend>
            <label><input type="radio" name="equipment_supplied" value="" checked /> Not specified</label>
            <label><input type="radio" name="equipment_supplied" value="yes" /> Yes</label>
            <label><input type="radio" name="equipment_supplied" value="no" /> No</label>
          </fieldset>

          <fieldset>
            <legend>Team required on signup?</legend>
            <label><input type="radio" name="team_required" value="" checked /> Not specified</label>
            <label><input type="radio" name="team_required" value="yes" /> Yes</label>
            <label><input type="radio" name="team_required" value="no" /> No</label>
          </fieldset>
        </div>

        <label>
          Additional notes (250 char max)
          <textarea name="notes" maxlength="250"></textarea>
        </label>

        <label>
          Photo
          <input type="file" name="photo" accept="image/jpeg,image/png,image/webp" />
          <span class="field-hint">JPEG, PNG, or WebP — 5MB max</span>
        </label>

        <div class="recurring-only">
          <fieldset>
            <legend>Visibility</legend>
            <label><input type="radio" name="visibility" value="public" checked /> Public (Open Gym)</label>
            <label><input type="radio" name="visibility" value="private" /> Private (Club)</label>
          </fieldset>
        </div>
      </details>

      <button type="submit">Submit listing</button>
    </form>

    <p id="submit-message" role="status"></p>
  </main>
</BaseLayout>

<style>
  .submit-page {
    width: 100%;
    max-width: 32rem;
    margin: 0 auto;
    padding: 2rem 1rem 4rem;

    form:not([hidden]) {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
    }

    fieldset {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
      padding: 0;
      border: none;

      legend {
        margin-bottom: 0.25rem;
        font-size: 0.875rem;
        font-weight: 600;
      }

      label {
        display: flex;
        flex-direction: row;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.875rem;
        font-weight: 400;
      }
    }

    label {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
      font-size: 0.875rem;
    }

    h1 {
      font-family: var(--font-display);
      font-weight: 700;
      letter-spacing: -0.01em;
    }

    .field-row {
      display: flex;
      gap: 1rem;

      label {
        flex: 1;
      }
    }

    #payment-types-field[hidden] {
      display: none;
    }

    .optional-fields {
      summary {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: #666;
        cursor: pointer;
      }

      &[open] summary {
        margin-bottom: 1.25rem;
      }

      &[open] {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
      }
    }

    .tournament-only[hidden],
    .league-only[hidden],
    .recurring-only[hidden],
    .days-time-section[hidden] {
      display: none;
    }

    /* Honeypot — present in the DOM (some bots skip the [hidden]
       attribute specifically) but invisible and unreachable for a real
       user: off-screen, untabbable, not announced to screen readers. */
    .honeypot-field {
      position: absolute;
      width: 1px;
      height: 1px;
      overflow: hidden;
      left: -9999px;
    }

    .field-hint {
      font-size: 0.75rem;
      font-weight: 400;
      color: #666;
    }

    input[type="text"],
    input[type="url"],
    input[type="date"],
    input[type="month"],
    select,
    textarea {
      padding: 0.5rem;
      font-size: 1rem;
      font-family: inherit;
      border: 1px solid #ccc;
      border-radius: var(--radius-sharp);
    }

    button[type="submit"] {
      padding: 0.7rem;
      font-family: var(--font-mono);
      font-size: 0.85rem;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: white;
      background: var(--color-accent);
      border: none;
      border-radius: var(--radius-sharp);
      cursor: pointer;
      transition: opacity var(--motion-base);
    }

    button[type="submit"]:hover {
      opacity: 0.88;
    }

    button[type="submit"]:active {
      transform: scale(0.97);
      transition-duration: var(--motion-fast);
    }
  }

  .submit-tabs {
    display: flex;
    gap: 0.5rem;
    width: 100%;
    max-width: 32rem;
    margin: 1.5rem auto 0;
    padding: 0 1rem;
  }

  .submit-tab {
    padding: 0.5rem 1rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #666;
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    cursor: pointer;
  }

  .submit-tab[aria-selected="true"] {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }
</style>

<script>
  import { supabase } from '../lib/supabase/client';
  import { readDaysTimes } from '../lib/listings/daysTimes';
  import { uploadListingPhoto } from '../lib/listings/photoUpload';
  import type { NewListing } from '../types/listing';

  const form = document.querySelector<HTMLFormElement>('#submit-form');
  const message = document.querySelector<HTMLParagraphElement>('#submit-message');
  const authNotice = document.querySelector<HTMLParagraphElement>('#auth-notice');
  const heading = document.querySelector<HTMLHeadingElement>('#submit-heading');
  const listingKindInput = document.querySelector<HTMLInputElement>('#listing-kind-input');

  const TAB_HEADINGS: Record<string, string> = {
    recurring: 'Add a recurring meetup',
    tournament: 'Add a listing for an upcoming tournament',
    league: 'Add a listing for a league',
  };

  let activeTab = 'recurring';

  function setTab(tab: string) {
    activeTab = tab;
    if (listingKindInput) listingKindInput.value = tab;
    if (heading) heading.textContent = TAB_HEADINGS[tab] ?? TAB_HEADINGS.recurring;

    for (const tabBtn of document.querySelectorAll<HTMLButtonElement>('.submit-tab')) {
      tabBtn.setAttribute('aria-selected', String(tabBtn.dataset.tab === tab));
    }

    // Hiding a field via the [hidden] attribute also exempts any
    // `required` input inside it from constraint validation — so
    // toggling these is enough to make each tab enforce only its own
    // required fields, no extra validation-clearing logic needed.
    for (const el of document.querySelectorAll<HTMLElement>('.tournament-only')) {
      el.hidden = tab !== 'tournament';
    }
    for (const el of document.querySelectorAll<HTMLElement>('.league-only')) {
      el.hidden = tab !== 'league';
    }
    for (const el of document.querySelectorAll<HTMLElement>('.recurring-only')) {
      el.hidden = tab !== 'recurring';
    }
    // Leagues recur on a weekly schedule too, just like a meetup — only
    // a tournament's fixed start/end date makes a day-of-week schedule
    // not apply.
    for (const el of document.querySelectorAll<HTMLElement>('.days-time-section')) {
      el.hidden = tab === 'tournament';
    }

    const startDateInput = form?.elements.namedItem('start_date') as HTMLInputElement | null;
    const endDateInput = form?.elements.namedItem('end_date') as HTMLInputElement | null;
    if (startDateInput) startDateInput.required = tab === 'tournament';
    if (endDateInput) endDateInput.required = tab === 'tournament';

    // Unlike tournament's dates, a league's start/end month are
    // optional (Robert's call — keeping them current for an
    // open-ended, ongoing league was more upkeep than it was worth),
    // so no `required` toggling for these.
  }

  for (const tabBtn of document.querySelectorAll<HTMLButtonElement>('.submit-tab')) {
    tabBtn.addEventListener('click', () => {
      if (tabBtn.dataset.tab) setTab(tabBtn.dataset.tab);
    });
  }

  // Cost amount only makes sense once "Paid" is picked — keeps it out
  // of the way otherwise instead of looking like an unrelated field.
  const paymentTypesField = document.querySelector<HTMLLabelElement>('#payment-types-field');
  const paymentTypesInput = paymentTypesField?.querySelector<HTMLInputElement>('input[name="payment_types"]');
  for (const costRadio of document.querySelectorAll<HTMLInputElement>('input[name="cost"]')) {
    costRadio.addEventListener('change', () => {
      if (!paymentTypesField) return;
      paymentTypesField.hidden = costRadio.value !== 'paid' || !costRadio.checked;
      if (paymentTypesField.hidden && paymentTypesInput) paymentTypesInput.value = '';
    });
  }

  let currentUserId: string | null = null;

  // onAuthStateChange fires immediately on subscribe with the current
  // session, so this also covers the initial render.
  supabase.auth.onAuthStateChange((_event, session) => {
    currentUserId = session?.user.id ?? null;
    if (form) form.hidden = !currentUserId;
    if (authNotice) authNotice.hidden = Boolean(currentUserId);
  });

  // "YYYY-MM" (native <input type="month"> format) -> the first/last
  // calendar day of that month, as plain "YYYY-MM-DD" — the API only
  // ever deals in start_date/end_date, regardless of which tab's UI
  // produced them. Day 0 of the *next* month is a standard JS trick for
  // "last day of this month" that avoids hardcoding days-per-month.
  function firstDayOfMonth(month: string): string {
    return `${month}-01`;
  }
  function lastDayOfMonth(month: string): string {
    const [year, monthNum] = month.split('-').map(Number);
    const lastDay = new Date(year, monthNum, 0).getDate();
    return `${month}-${String(lastDay).padStart(2, '0')}`;
  }

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    if (!currentUserId) return;

    const formData = new FormData(form);
    const isTournament = activeTab === 'tournament';
    const isLeague = activeTab === 'league';
    const isDatedListing = isTournament || isLeague;

    // The lat/lng hidden inputs default to empty strings, and
    // Number('') is 0 (not NaN) — so a listing with no address picked
    // and no pin dropped used to submit successfully with (0,0),
    // silently creating an unapprovable listing. Block it here instead,
    // unless a Google Maps link was provided — the server can try to
    // decode coordinates from that as a fallback.
    const lat = Number(formData.get('lat'));
    const lng = Number(formData.get('lng'));
    const hasRealLocation = !(lat === 0 && lng === 0);
    const hasMapsLink = Boolean((formData.get('google_maps_url') as string)?.trim());
    if (!hasRealLocation && !hasMapsLink) {
      if (message) {
        message.textContent =
          'Please select an address from the suggestions, drop a pin on the map, or paste a Google Maps link for this location.';
      }
      return;
    }

    let startDate: string | null = null;
    let endDate: string | null = null;
    if (isTournament) {
      startDate = (formData.get('start_date') as string) || null;
      endDate = (formData.get('end_date') as string) || null;
      if (!startDate || !endDate || endDate < startDate) {
        if (message) message.textContent = 'Please enter a valid start and end date for the tournament.';
        return;
      }
    } else if (isLeague) {
      // Unlike a tournament's dates, these are optional — leaving both
      // blank is a deliberate choice to just note a league exists and
      // point people to its own site for current dates, not an error.
      const startMonth = (formData.get('start_month') as string) || null;
      const endMonth = (formData.get('end_month') as string) || null;
      if (startMonth || endMonth) {
        if (!startMonth || !endMonth || endMonth < startMonth) {
          if (message) message.textContent = 'Please enter both a start and end month, or leave both blank.';
          return;
        }
        startDate = firstDayOfMonth(startMonth);
        endDate = lastDayOfMonth(endMonth);
      }
    }

    const cost = formData.get('cost');
    const signupRequired = formData.get('signup_required');
    const equipmentSupplied = formData.get('equipment_supplied');
    const teamRequired = formData.get('team_required');

    let photoUrl: string | null = null;
    const photoFile = formData.get('photo');
    if (photoFile instanceof File && photoFile.size > 0) {
      const result = await uploadListingPhoto(photoFile);
      if (!result.ok) {
        if (message) message.textContent = result.error;
        return;
      }
      photoUrl = result.url;
    }

    const payload = {
      website: (formData.get('website') as string) || '',
      listing_kind: activeTab,
      start_date: isDatedListing ? startDate : null,
      end_date: isDatedListing ? endDate : null,
      type: formData.get('type') as NewListing['type'],
      cost: cost === '' ? null : (cost as NewListing['cost']),
      lat: Number(formData.get('lat')),
      lng: Number(formData.get('lng')),
      submitted_address: (formData.get('address_raw') as string) || null,
      google_maps_url: (formData.get('google_maps_url') as string) || null,
      // A tournament is a single dated event, not a weekly schedule —
      // sent as empty rather than reading the (hidden, untouched)
      // DayTimePicker fields. A league can have both a date range and an
      // optional weekly day, so it still reads the picker.
      days_times: isTournament ? [] : readDaysTimes(formData),
      signup_required: signupRequired === '' ? null : signupRequired === 'yes',
      name: (formData.get('name') as string) || null,
      external_link: (formData.get('external_link') as string) || null,
      min_skill_level: (formData.get('min_skill_level') as NewListing['min_skill_level']) || null,
      // Not asked of tournament/league submitters (their field lists
      // omit these) — always null for those kinds regardless of these
      // radios' default-checked state.
      equipment_supplied: isDatedListing ? null : equipmentSupplied === '' ? null : equipmentSupplied === 'yes',
      payment_types: (formData.get('payment_types') as string) || null,
      team_required: isDatedListing ? null : teamRequired === '' ? null : teamRequired === 'yes',
      notes: (formData.get('notes') as string) || null,
      // Visibility toggle isn't shown for tournaments/leagues — always public.
      visibility: (isDatedListing ? 'public' : formData.get('visibility')) as NewListing['visibility'],
      photo_url: photoUrl,
    };

    const { data: sessionData } = await supabase.auth.getSession();
    const token = sessionData.session?.access_token;

    const response = await fetch('/api/listings/submit', {
      method: 'POST',
      headers: { 'content-type': 'application/json', Authorization: `Bearer ${token}` },
      body: JSON.stringify(payload),
    });

    if (!response.ok) {
      const { error } = await response.json().catch(() => ({ error: 'Submission failed' }));
      if (message) message.textContent = error ?? 'Submission failed';
      return;
    }

    // Stash the success message for the map page's toast (sessionStorage
    // survives the redirect, unlike setting #submit-message here, which
    // the user would never see this page again to read).
    sessionStorage.setItem('fv-toast-message', 'Submitted! Your listing is pending review.');
    window.location.href = '/';
  });
</script>
