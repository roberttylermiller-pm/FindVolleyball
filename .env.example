# Supabase project settings — find these in Supabase dashboard > Project Settings > API
# Safe to expose to the browser (protected by Row Level Security policies).
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=

# Service role key — server-only, bypasses Row Level Security.
# Never prefix this with PUBLIC_ or expose it to the client.
SUPABASE_SERVICE_ROLE_KEY=
